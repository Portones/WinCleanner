<Window x:Class="WinCleaner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinCleaner.Views"
        xmlns:catViews="clr-namespace:WinCleaner.Views.Categories"
        xmlns:vm="clr-namespace:WinCleaner.ViewModels"
        xmlns:catVm="clr-namespace:WinCleaner.ViewModels.Categories"
        mc:Ignorable="d"
        Title="WinCleaner - Panel de Control Profesional" Height="720" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A" TextElement.Foreground="#F8FAFC"
        FontFamily="Segoe UI Variable Text, Segoe UI, Arial">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Estilo para el Botón de Notificación de Actualización -->
        <Style x:Key="UpdateNotifyButton" TargetType="Button">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#059669"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Panel Lateral (Sidebar) Compacto -->
            <ColumnDefinition Width="240"/>
            <!-- Área de Contenido Principal -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL LATERAL -->
        <Border Grid.Column="0" Background="#0B0F19" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo de la Aplicación -->
                <StackPanel Grid.Row="0" Margin="10,15,0,25">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,2A10,10,0,1,0,22,12,10,10,0,0,0,12,2Zm1,17.93V19a1,1,0,0,1-2,0v-1.07A8,8,0,0,1,4.07,13H5a1,1,0,0,1,0,2H4.07A8,8,0,0,1,11,4.07V5a1,1,0,0,1,2,0v-.93A8,8,0,0,1,19.93,11H19a1,1,0,0,1,0-2h.93A8,8,0,0,1,13,17.93Z" 
                              Fill="#6366F1" Width="26" Height="26" Margin="0,0,10,0"/>
                        <TextBlock Text="WinCleaner" FontSize="20" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Indicador Admin -->
                    <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Padding="6,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Administrador (Elevado)" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- BOTONES DE NAVEGACIÓN PRINCIPALES DINÁMICOS -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="MENÚ PRINCIPAL" FontSize="9.5" FontWeight="Bold" Foreground="#475569" Margin="5,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding NavigationItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Title}" 
                                        Style="{StaticResource SidebarNavButton}" 
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding Parameter}" 
                                        Tag="{Binding Parameter}" 
                                        Margin="0,0,0,6"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="OPCIONES" FontSize="9.5" FontWeight="Bold" Foreground="#475569" Margin="5,14,0,10"/>

                    <ItemsControl ItemsSource="{Binding OptionItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Title}" 
                                        Style="{StaticResource SidebarNavButton}" 
                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                        CommandParameter="{Binding Parameter}" 
                                        Tag="{Binding Parameter}" 
                                        Margin="0,0,0,8"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Footer del Sidebar -->
                <StackPanel Grid.Row="2" Margin="10,0,0,10">
                    <!-- Botón de Notificación de Actualización -->
                    <Button Content="📥 Actualización Disponible" 
                            Command="{Binding NavigateCommand}" 
                            CommandParameter="Settings" 
                            Style="{StaticResource UpdateNotifyButton}"
                            Visibility="{Binding SettingsViewModel.IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Left"/>
                    
                    <TextBlock Text="Versión 1.14.0" FontSize="11" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock Text=".NET 9.0 x64" FontSize="11" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock FontSize="11">
                        <Run Text="Desarrollado por" Foreground="#475569"/>
                        <Hyperlink NavigateUri="https://portpytech.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#6366F1" TextDecorations="None">
                            <Run Text=" PortPyTech" FontWeight="Bold"/>
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ÁREA DE CONTENIDO PRINCIPAL DINÁMICA -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="10">
            <ContentControl.Resources>
                <!-- Mapeo de ViewModels de Categoría a Vistas -->
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <local:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type catVm:DiagnosticsCategoryViewModel}">
                    <catViews:DiagnosticsCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type catVm:CleanupCategoryViewModel}">
                    <catViews:CleanupCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type catVm:DiskCategoryViewModel}">
                    <catViews:DiskCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type catVm:AppCategoryViewModel}">
                    <catViews:AppCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type catVm:OptimizationCategoryViewModel}">
                    <catViews:OptimizationCategoryView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <local:SettingsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
