<Window x:Class="WinCleaner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WinCleaner.Views"
        xmlns:vm="clr-namespace:WinCleaner.ViewModels"
        mc:Ignorable="d"
        Title="WinCleaner - Panel de Control Profesional" Height="680" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A" TextElement.Foreground="#F8FAFC"
        FontFamily="Segoe UI Variable Text, Segoe UI, Arial">
    
    <Window.Resources>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Panel Lateral (Sidebar) -->
            <ColumnDefinition Width="230"/>
            <!-- Área de Contenido Principal -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL LATERAL -->
        <Border Grid.Column="0" Background="#0B0F19" BorderBrush="#1E293B" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo de la Aplicación -->
                <StackPanel Grid.Row="0" Margin="10,15,0,25">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,2A10,10,0,1,0,22,12,10,10,0,0,0,12,2Zm1,17.93V19a1,1,0,0,1-2,0v-1.07A8,8,0,0,1,4.07,13H5a1,1,0,0,1,0,2H4.07A8,8,0,0,1,11,4.07V5a1,1,0,0,1,2,0v-.93A8,8,0,0,1,19.93,11H19a1,1,0,0,1,0-2h.93A8,8,0,0,1,13,17.93Z" 
                              Fill="#6366F1" Width="26" Height="26" Margin="0,0,10,0"/>
                        <TextBlock Text="WinCleaner" FontSize="20" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Indicador Admin -->
                    <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Padding="6,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Administrador (Elevado)" FontSize="9" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Botones de Navegación con ScrollViewer -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,-10,0" Padding="0,0,10,0">
                    <StackPanel>
                        <!-- SECCIÓN 1: ESTADO Y DIAGNÓSTICO -->
                        <TextBlock Text="DIAGNÓSTICO Y ESTADO" FontSize="9.5" FontWeight="Bold" Foreground="#475569" Margin="5,0,0,6"/>
                        <Button Content="Dashboard" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Dashboard" Tag="Dashboard" Margin="0,0,0,4"/>
                        <Button Content="Analizador de Disco" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="DiskAnalyzer" Tag="DiskAnalyzer" Margin="0,0,0,18"/>

                        <!-- SECCIÓN 2: LIMPIEZA DE ESPACIO -->
                        <TextBlock Text="LIMPIEZA DE ESPACIO" FontSize="9.5" FontWeight="Bold" Foreground="#475569" Margin="5,0,0,6"/>
                        <Button Content="Limpieza Avanzada" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Cleanup" Tag="Cleanup" Margin="0,0,0,4"/>
                        <Button Content="Archivos Duplicados" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Duplicates" Tag="Duplicates" Margin="0,0,0,4"/>
                        <Button Content="Limpiador de Fotos" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="PhotosCleanup" Tag="PhotosCleanup" Margin="0,0,0,4"/>
                        <Button Content="Desinstalador" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Uninstaller" Tag="Uninstaller" Margin="0,0,0,18"/>

                        <!-- SECCIÓN 3: OPTIMIZACIÓN Y SISTEMA -->
                        <TextBlock Text="OPTIMIZACIÓN Y SISTEMA" FontSize="9.5" FontWeight="Bold" Foreground="#475569" Margin="5,0,0,6"/>
                        <Button Content="Rendimiento y Red" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Performance" Tag="Performance" Margin="0,0,0,4"/>
                        <Button Content="Actualizar Apps" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Updater" Tag="Updater" Margin="0,0,0,4"/>
                        <Button Content="Gestión de Inicio" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Startup" Tag="Startup" Margin="0,0,0,4"/>
                        <Button Content="Servicios de Windows" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Services" Tag="Services" Margin="0,0,0,4"/>
                        <Button Content="Menú Contextual" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="ContextMenu" Tag="ContextMenu" Margin="0,0,0,18"/>

                        <!-- SECCIÓN 4: CONFIGURACIÓN -->
                        <TextBlock Text="OPCIONES" FontSize="9.5" FontWeight="Bold" Foreground="#475569" Margin="5,0,0,6"/>
                        <Button Content="Configuración" Style="{StaticResource SidebarNavButton}" Command="{Binding NavigateCommand}" CommandParameter="Settings" Tag="Settings" Margin="0,0,0,8"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer del Sidebar -->
                <StackPanel Grid.Row="2" Margin="10,0,0,10">
                    <TextBlock Text="Versión 1.2.0" FontSize="11" Foreground="#475569" Margin="0,0,0,4"/>
                    <TextBlock Text=".NET 9.0 x64" FontSize="11" Foreground="#475569"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ÁREA DE CONTENIDO PRINCIPAL DINÁMICA -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" Margin="15">
            <ContentControl.Resources>
                <!-- Mapeo de ViewModels a Controles de Usuario (Vistas) -->
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <local:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:CleanupViewModel}">
                    <local:CleanupView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:DuplicateFilesViewModel}">
                    <local:DuplicateFilesView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:StartupViewModel}">
                    <local:StartupView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ServicesViewModel}">
                    <local:ServicesView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ContextMenuViewModel}">
                    <local:ContextMenuView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:UninstallerViewModel}">
                    <local:UninstallerView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:DiskAnalyzerViewModel}">
                    <local:DiskAnalyzerView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:PerformanceViewModel}">
                    <local:PerformanceView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:UpdaterViewModel}">
                    <local:UpdaterView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:PhotosCleanupViewModel}">
                    <local:PhotosCleanupView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <local:SettingsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
