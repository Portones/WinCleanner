<UserControl x:Class="WinCleaner.Views.TemperatureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             x:Name="TemperatureRoot">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Alerta Global -->
            <RowDefinition Height="Auto"/>
            <!-- Fila de Gauges -->
            <RowDefinition Height="Auto"/>
            <!-- Controles y Filtros -->
            <RowDefinition Height="Auto"/>
            <!-- Tabla de Detalles -->
            <RowDefinition Height="*"/>
            <!-- Pie de Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Temperatura del Hardware" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Monitoree en tiempo real la temperatura de la CPU, GPU y almacenamiento para prevenir sobrecalentamientos." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ALERTA GLOBAL -->
        <Border Grid.Row="1" Visibility="{Binding ShowGlobalWarning, Converter={StaticResource BooleanToVisibilityConverter}}" 
                Background="#1E1B4B" BorderBrush="#4338CA" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" 
                      Fill="#6366F1" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Grid.Column="1" Text="{Binding GlobalWarningText}" FontSize="12" FontWeight="SemiBold" Foreground="#E0E7FF" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- FILA DE GAUGES -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Gauge 1: CPU -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Procesador (CPU)" FontSize="14.5" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <!-- Gráfica de Progreso Circular -->
                    <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8">
                        <Grid Width="110" Height="110">
                            <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                            <Ellipse Stroke="#6366F1" StrokeThickness="9" Width="100" Height="100"
                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.StrokeDashArray>
                                    <Binding Path="CpuTemp" Converter="{StaticResource CircularProgressConverter}" ConverterParameter="100"/>
                                </Ellipse.StrokeDashArray>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CpuTemp, StringFormat='{}{0:F0}°C'}" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                                <TextBlock Text="Temperatura" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Temperatura del procesador en tiempo real" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Gauge 2: GPU -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Tarjeta Gráfica (GPU)" FontSize="14.5" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <!-- Gráfica de Progreso Circular -->
                    <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8">
                        <Grid Width="110" Height="110">
                            <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                            <Ellipse Stroke="#EC4899" StrokeThickness="9" Width="100" Height="100"
                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.StrokeDashArray>
                                    <Binding Path="GpuTemp" Converter="{StaticResource CircularProgressConverter}" ConverterParameter="100"/>
                                </Ellipse.StrokeDashArray>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding GpuTemp, StringFormat='{}{0:F0}°C'}" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                                <TextBlock Text="Temperatura" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Temperatura de la GPU en tiempo real" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Gauge 3: Disco -->
            <Border Grid.Column="4" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Almacenamiento (SSD/HDD)" FontSize="14.5" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center" Margin="0,0,0,12"/>

                    <!-- Gráfica de Progreso Circular -->
                    <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,8">
                        <Grid Width="110" Height="110">
                            <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                            <Ellipse Stroke="#10B981" StrokeThickness="9" Width="100" Height="100"
                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.StrokeDashArray>
                                    <Binding Path="DiskTemp" Converter="{StaticResource CircularProgressConverter}" ConverterParameter="100"/>
                                </Ellipse.StrokeDashArray>
                            </Ellipse>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DiskTemp, StringFormat='{}{0:F0}°C'}" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                                <TextBlock Text="Temperatura" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Temperatura del disco de sistema" FontSize="11" Foreground="#64748B" HorizontalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- CONTROLES Y FILTROS -->
        <Border Grid.Row="3" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Detalles del Sensor de Hardware" FontSize="14" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>

                <CheckBox Grid.Column="1" IsChecked="{Binding IsAutoRefreshEnabled, Mode=TwoWay}" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock Text="Actualizar automáticamente (2s)" FontSize="12" Foreground="#94A3B8"/>
                </CheckBox>

                <Button Grid.Column="2" Content="Refrescar" Command="{Binding RefreshCommand}" Style="{StaticResource SidebarButton}" Height="32" Padding="15,0" Margin="15,0,0,0"/>
            </Grid>
        </Border>

        <!-- TABLA DE DETALLES -->
        <Border Grid.Row="4" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Cabecera de columnas personalizada -->
                <Border Grid.Row="0" Background="#0B0F19" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="COMPONENTE" Style="{StaticResource ColumnHeaderStyle}"/>
                        <TextBlock Grid.Column="1" Text="TEMPERATURA ACTUAL" Style="{StaticResource ColumnHeaderStyle}"/>
                        <TextBlock Grid.Column="2" Text="ESTADO TÉRMICO" Style="{StaticResource ColumnHeaderStyle}"/>
                    </Grid>
                </Border>

                <!-- Filas de datos -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Temperatures}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,12" BorderBrush="#1A2540" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                            <ColumnDefinition Width="1.5*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Componente -->
                                        <TextBlock Grid.Column="0" Text="{Binding ComponentName}" FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9" VerticalAlignment="Center"/>

                                        <!-- Temperatura -->
                                        <TextBlock Grid.Column="1" Text="{Binding ValueText}" FontSize="13" Foreground="{Binding StatusColor}" FontWeight="Bold" VerticalAlignment="Center"/>

                                        <!-- Estado -->
                                        <Border Grid.Column="2" Background="#0F172A" BorderBrush="{Binding StatusColor}" BorderThickness="1" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" Foreground="{Binding StatusColor}" TextAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="5" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
