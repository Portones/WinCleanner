<UserControl x:Class="WinCleaner.Views.DriverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Estilo de cabecera de columna -->
        <Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Estilos para los RadioButtons de filtro tipo pestaña -->
        <Style x:Key="FilterRadioButton" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#818CF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Dashboard de Resumen -->
            <RowDefinition Height="Auto"/>
            <!-- Sugerencia Inteligente -->
            <RowDefinition Height="Auto"/>
            <!-- Barra de Acciones e Inicios -->
            <RowDefinition Height="Auto"/>
            <!-- Selector de Filtros -->
            <RowDefinition Height="Auto"/>
            <!-- Panel Principal / Tablas -->
            <RowDefinition Height="*"/>
            <!-- Pie de Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Gestor de Controladores (Drivers)" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Analice el estado y firma digital de los controladores de hardware y busque actualizaciones oficiales pendientes." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- DASHBOARD DE RESUMEN -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tarjeta 1: Total Escaneados -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Controladores Firmados" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalDriversCount}" FontSize="24" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,4,0,0"/>
                    <TextBlock Text="Dispositivos activos en el sistema" FontSize="10.5" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tarjeta 2: Antiguos -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Controladores Antiguos" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding OutdatedDriversCount}" FontSize="24" FontWeight="Bold" Foreground="#F59E0B" Margin="0,4,0,0"/>
                    <TextBlock Text="Con más de 3 años de antigüedad" FontSize="10.5" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tarjeta 3: Actualizaciones Oficiales -->
            <Border Grid.Column="4" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Actualizaciones Recomendadas" FontSize="11" Foreground="#64748B" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding AvailableUpdatesCount}" FontSize="24" FontWeight="Bold" Foreground="#10B981" Margin="0,4,0,0"/>
                    <TextBlock Text="Canal oficial de Windows Update" FontSize="10.5" Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ALERTA DE SUGERENCIA DE CONTROLADORES CONTEXTUAL -->
        <Border Grid.Row="2" Background="#1E293B" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15"
                Visibility="{Binding ShowDriverSuggestion, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding DriverSuggestionText}" FontSize="12.5" FontWeight="SemiBold" Foreground="#F8FAFC" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Buscar Actualizaciones" Style="{StaticResource ActionButton}" Command="{Binding OpenWindowsUpdateCommand}" Height="30" Padding="15,0" Margin="15,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- BARRA DE ACCIONES E INICIOS -->
        <Border Grid.Row="3" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Caja de Búsqueda -->
                <Grid Grid.Column="0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Background="#0F172A" BorderBrush="#334155" Foreground="#F8FAFC" Padding="25,5,10,5" Height="30"/>
                    <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                          Fill="#64748B" Width="13" Height="13" Margin="8,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                </Grid>

                <!-- Botón Administrador de Dispositivos -->
                <Button Grid.Column="2" Content="Administrador de Dispositivos" Command="{Binding OpenDeviceManagerCommand}" Style="{StaticResource SidebarButton}" Height="30" Padding="15,0" Margin="10,0,0,0"/>

                <!-- Botón Buscar Actualizaciones -->
                <Button Grid.Column="3" Content="Buscar Actualizaciones" Command="{Binding ScanCommand}" Style="{StaticResource ActionButton}" Height="30" Padding="15,0" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- SELECTOR DE FILTROS (CATEGORÍAS) -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="5,0,0,10">
            <RadioButton Content="Todos" IsChecked="{Binding SelectedCategory, ConverterParameter=TODOS, Converter={StaticResource EqualityConverter}}" Style="{StaticResource FilterRadioButton}"/>
            <RadioButton Content="Vídeo" IsChecked="{Binding SelectedCategory, ConverterParameter=DISPLAY, Converter={StaticResource EqualityConverter}}" Style="{StaticResource FilterRadioButton}"/>
            <RadioButton Content="Red / Wi-Fi" IsChecked="{Binding SelectedCategory, ConverterParameter=NET, Converter={StaticResource EqualityConverter}}" Style="{StaticResource FilterRadioButton}"/>
            <RadioButton Content="Audio" IsChecked="{Binding SelectedCategory, ConverterParameter=MEDIA, Converter={StaticResource EqualityConverter}}" Style="{StaticResource FilterRadioButton}"/>
            <RadioButton Content="Bluetooth" IsChecked="{Binding SelectedCategory, ConverterParameter=BLUETOOTH, Converter={StaticResource EqualityConverter}}" Style="{StaticResource FilterRadioButton}"/>
            <RadioButton Content="Otros" IsChecked="{Binding SelectedCategory, ConverterParameter=OTROS, Converter={StaticResource EqualityConverter}}" Style="{StaticResource FilterRadioButton}"/>
        </StackPanel>

        <!-- TAB CONTROL PARA DIVISION ENTRE INSTALADOS Y ACTUALIZACIONES -->
        <TabControl Grid.Row="5" Background="Transparent" BorderThickness="0" Padding="0">
            <TabControl.Resources>
                <!-- Ocultar cabeceras por defecto para usar un estilo plano segmentado -->
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.Resources>

            <TabItem IsSelected="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- TABLA DE CONTROLADORES INSTALADOS -->
                    <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Cabecera de columnas personalizada -->
                            <Border Grid.Row="0" Background="#0B0F19" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="DISPOSITIVO" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="1" Text="PROVEEDOR" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="FECHA" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="VERSIÓN" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="4" Text="ESTADO" Style="{StaticResource ColumnHeaderStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Filas de datos -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding FilteredDrivers}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,12" BorderBrush="#1A2540" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2.5*"/>
                                                        <ColumnDefinition Width="1.5*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                        <ColumnDefinition Width="1*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Nombre -->
                                                    <TextBlock Grid.Column="0" Text="{Binding DeviceName}" FontSize="12.5" FontWeight="SemiBold" Foreground="#F1F5F9" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                                                    <!-- Proveedor -->
                                                    <TextBlock Grid.Column="1" Text="{Binding DriverProvider}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>

                                                    <!-- Fecha -->
                                                    <TextBlock Grid.Column="2" Text="{Binding DriverDateString}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>

                                                    <!-- Versión -->
                                                    <TextBlock Grid.Column="3" Text="{Binding DriverVersion}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>

                                                    <!-- Estado -->
                                                    <Border Grid.Column="4" Background="#0F172A" BorderBrush="{Binding StatusColor}" BorderThickness="1" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding StatusText}" FontSize="10" FontWeight="Bold" Foreground="{Binding StatusColor}" TextAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="6" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" Visibility="{Binding HasAvailableUpdates, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Actualizaciones de controladores listas en Windows Update" FontSize="12" Foreground="#10B981" VerticalAlignment="Center"/>
                    <Button Content="Actualizar en Windows Update" Command="{Binding OpenWindowsUpdateCommand}" Style="{StaticResource SidebarButton}" Height="24" Padding="10,0" Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
