<UserControl x:Class="WinCleaner.Views.DuplicateFilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
             
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Panel de Acciones Rápidas -->
            <RowDefinition Height="Auto"/>
            <!-- Lista de Grupos de Duplicados -->
            <RowDefinition Height="*"/>
            <!-- Pie de Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Buscador de Archivos Duplicados" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Localiza de forma segura archivos idénticos en disco (mediante tamaño y hash SHA-256). Conserve al menos una copia de cada archivo." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- PANEL DE ACCIONES RÁPIDAS -->
        <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Buscar Duplicados" Style="{StaticResource ActionButton}" Command="{Binding ScanCommand}" IsEnabled="{Binding CanScan}" Margin="0,0,10,0"/>
                
                <Button Grid.Column="1" Content="Cancelar" Style="{StaticResource SidebarButton}" Command="{Binding CancelScanCommand}" IsEnabled="{Binding IsScanning}" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Escaneando y calculando firmas SHA-256..." FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" Height="6" Style="{StaticResource ModernProgressBar}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsCleaning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Eliminando duplicados..." FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" Height="6" Style="{StaticResource ModernProgressBar}"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Eliminar Copias Seleccionadas" Command="{Binding CleanCommand}" IsEnabled="{Binding CanClean}" Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                            <Setter Property="Background" Value="#EF4444"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#DC2626"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#475569"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- LISTA DE GRUPOS DE DUPLICADOS -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <ItemsControl ItemsSource="{Binding DuplicateGroups}">
                <ItemsControl.ItemTemplate>
                    <!-- Tarjeta para cada grupo de duplicados -->
                    <DataTemplate>
                        <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Título del Grupo de Duplicado -->
                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-2 10H7v-2h10v2z" 
                                              Fill="#818CF8" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding GroupTitle}" FontSize="14" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Hash, StringFormat='SHA256: {0}'}" FontSize="10" Foreground="#64748B" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas"/>
                                </Grid>

                                <!-- Lista de archivos en el grupo -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Files}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#151F32" BorderBrush="#2D3B51" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Checkbox de selección para eliminar -->
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                    
                                                    <!-- Ruta y detalles de modificación -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Path}" FontSize="12" Foreground="#F8FAFC" TextTrimming="CharacterEllipsis">
                                                            <TextBlock.ToolTip>
                                                                <ToolTip Content="{Binding Path}"/>
                                                            </TextBlock.ToolTip>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding LastModified, StringFormat='Última modificación: {0:dd/MM/yyyy HH:mm}'}" FontSize="10" Foreground="#64748B" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Peso individual -->
                                                    <TextBlock Grid.Column="2" Text="{Binding SizeText}" FontSize="12" Foreground="#10B981" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="3" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Espacio Redundante: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPotentialSpaceText}" FontSize="12" Foreground="#F8FAFC" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="Espacio a Liberar: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedSpaceText}" FontSize="12" Foreground="#10B981" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
