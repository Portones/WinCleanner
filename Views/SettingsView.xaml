<UserControl x:Class="WinCleaner.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Estilo para la lista de directorios -->
        <Style x:Key="DirectoryListBox" TargetType="ListBox">
            <Setter Property="Background" Value="#151F32"/>
            <Setter Property="BorderBrush" Value="#2D3B51"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Height" Value="110"/>
        </Style>

        <Style x:Key="DirectoryListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón de eliminar carpeta (rojo discreto) -->
        <Style x:Key="RemoveFolderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F87171"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Contenido Escroleable -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Configuración General" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Personalice el comportamiento de los escaneos, límites de tamaño y directorios del limpiador." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- CONTENIDO ESCROLEABLE -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,5">
            <StackPanel>
                <!-- CARD 1: OPCIONES DE LIMPIEZA -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Comportamiento del Limpiador" FontSize="16" FontWeight="Bold" Foreground="#818CF8" Margin="0,0,0,15"/>
                        
                        <!-- Toggle Papelera -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Omitir Papelera de Reciclaje (Borrado Permanente)" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Los archivos se eliminarán permanentemente de forma inmediata. Requiere doble confirmación antes de limpiar." FontSize="11" Foreground="#64748B" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1" IsChecked="{Binding BypassRecycleBin, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,15"/>

                        <!-- Slider Archivos Grandes -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                <TextBlock Text="Tamaño Mínimo para Archivos Grandes" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Especifica el tamaño mínimo de un archivo para ser catalogado como 'Archivo Grande' (desde 10 MB hasta 2 GB)." FontSize="11" Foreground="#64748B" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding MinLargeFileSizeMb}" FontSize="15" FontWeight="Bold" Foreground="#10B981"/>
                                <TextBlock Text=" MB" FontSize="15" FontWeight="Bold" Foreground="#10B981"/>
                            </StackPanel>

                            <Slider Grid.Row="1" Grid.ColumnSpan="2" Minimum="10" Maximum="2000" TickFrequency="50" IsSnapToTickEnabled="True" Value="{Binding MinLargeFileSizeMb, Mode=TwoWay}" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD 2: INICIO DE LA APLICACIÓN -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Inicio de la Aplicación" FontSize="16" FontWeight="Bold" Foreground="#818CF8" Margin="0,0,0,15"/>
                        
                        <!-- Toggle Iniciar con Windows -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Iniciar WinCleaner al arrancar Windows" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Ejecuta automáticamente la aplicación al iniciar sesión en el equipo para disponer de diagnósticos e inicio rápido." FontSize="11" Foreground="#64748B" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1" IsChecked="{Binding StartWithWindows, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Toggle Iniciar Minimizado (Solo visible si StartWithWindows es true) -->
                        <Grid Visibility="{Binding StartWithWindows, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Height="1" Background="#334155" Margin="0,0,0,15" Grid.ColumnSpan="2" VerticalAlignment="Top"/>
                            
                            <StackPanel Grid.Column="0" Margin="0,15,0,0">
                                <TextBlock Text="Iniciar minimizado en la bandeja del sistema (SysTray)" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="WinCleaner se iniciará silenciosamente en segundo plano sin desplegar la ventana principal." FontSize="11" Foreground="#64748B" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1" IsChecked="{Binding StartMinimized, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,15,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD 2: CARPETAS EXCLUIDAS -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Carpetas Excluidas (Lista Negra)" FontSize="16" FontWeight="Bold" Foreground="#818CF8"/>
                                <TextBlock Text="Estas carpetas y sus subcarpetas se ignorarán por completo durante los análisis de archivos grandes y temporales." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <Button Content="+ Añadir" Style="{StaticResource SidebarButton}" Command="{Binding AddExcludedDirectoryCommand}" HorizontalAlignment="Right" Padding="12,6" FontSize="12" Margin="0"/>
                        </Grid>

                        <ListBox Grid.Row="2" ItemsSource="{Binding ExcludedDirectories}" Style="{StaticResource DirectoryListBox}" ItemContainerStyle="{StaticResource DirectoryListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" Foreground="#F8FAFC" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" Content="Eliminar" Style="{StaticResource RemoveFolderButton}" Command="{Binding DataContext.RemoveExcludedDirectoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="10,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- CARD 3: CARPETAS PERSONALIZADAS DE ESCANEO -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Carpetas de Escaneo Personalizadas" FontSize="16" FontWeight="Bold" Foreground="#818CF8"/>
                                <TextBlock Text="Agregue carpetas secundarias o discos adicionales para que se analicen en busca de archivos grandes y duplicados." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            
                            <Button Content="+ Añadir" Style="{StaticResource SidebarButton}" Command="{Binding AddCustomDirectoryCommand}" HorizontalAlignment="Right" Padding="12,6" FontSize="12" Margin="0"/>
                        </Grid>

                        <ListBox Grid.Row="2" ItemsSource="{Binding CustomScanDirectories}" Style="{StaticResource DirectoryListBox}" ItemContainerStyle="{StaticResource DirectoryListBoxItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding}" FontSize="12" Foreground="#F8FAFC" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        <Button Grid.Column="1" Content="Eliminar" Style="{StaticResource RemoveFolderButton}" Command="{Binding DataContext.RemoveCustomDirectoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Margin="10,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- CARD 4: PROGRAMAR MANTENIMIENTO AUTOMÁTICO -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Mantenimiento Programado" FontSize="16" FontWeight="Bold" Foreground="#818CF8" Margin="0,0,0,15"/>

                        <!-- Habilitar Checkbox -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Habilitar Limpieza Automática en Segundo Plano" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Registra una tarea silenciosa en Windows para limpiar archivos temporales automáticamente según la frecuencia programada." FontSize="11" Foreground="#64748B" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            
                            <CheckBox Grid.Column="1" IsChecked="{Binding MaintenanceTaskEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,15"/>

                        <!-- Panel de Parámetros (Habilitado solo si la tarea está activa) -->
                        <StackPanel IsEnabled="{Binding MaintenanceTaskEnabled}">
                            
                            <!-- Frecuencia -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Frecuencia de Ejecución" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                    <TextBlock Text="Elija con qué frecuencia Windows debe disparar la limpieza automática." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <ComboBox Grid.Column="1" SelectedValue="{Binding MaintenanceFrequency, Mode=TwoWay}" SelectedValuePath="Tag" Height="28" VerticalAlignment="Center" Background="#0F172A" BorderBrush="#334155" Foreground="#F8FAFC">
                                    <ComboBoxItem Content="Semanal" Tag="weekly"/>
                                    <ComboBoxItem Content="Mensual" Tag="monthly"/>
                                    <ComboBoxItem Content="Al iniciar sesión" Tag="onlogon"/>
                                    <ComboBoxItem Content="Al estar inactivo (Idle)" Tag="idle"/>
                                </ComboBox>
                            </Grid>

                            <!-- Parámetros Semanal (Día de la semana) -->
                            <Grid Margin="0,0,0,15">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MaintenanceFrequency}" Value="weekly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Día de la Semana" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                    <TextBlock Text="Seleccione el día en que se ejecutará la tarea." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                                <ComboBox Grid.Column="1" SelectedValue="{Binding MaintenanceDay, Mode=TwoWay}" SelectedValuePath="Tag" Height="28" VerticalAlignment="Center" Background="#0F172A" BorderBrush="#334155" Foreground="#F8FAFC">
                                    <ComboBoxItem Content="Lunes" Tag="MON"/>
                                    <ComboBoxItem Content="Martes" Tag="TUE"/>
                                    <ComboBoxItem Content="Miércoles" Tag="WED"/>
                                    <ComboBoxItem Content="Jueves" Tag="THU"/>
                                    <ComboBoxItem Content="Viernes" Tag="FRI"/>
                                    <ComboBoxItem Content="Sábado" Tag="SAT"/>
                                    <ComboBoxItem Content="Domingo" Tag="SUN"/>
                                </ComboBox>
                            </Grid>

                            <!-- Parámetros Mensual (Día del mes) -->
                            <Grid Margin="0,0,0,15">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MaintenanceFrequency}" Value="monthly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Día del Mes" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                    <TextBlock Text="Ingrese el día del mes (1 al 31)." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding MaintenanceDay, Mode=TwoWay}" Height="28" VerticalAlignment="Center" Background="#0F172A" BorderBrush="#334155" Foreground="#F8FAFC" Padding="5,3"/>
                            </Grid>

                            <!-- Hora de inicio (Para semanal y mensual) -->
                            <Grid Margin="0,0,0,15">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MaintenanceFrequency}" Value="weekly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MaintenanceFrequency}" Value="monthly">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Hora de Inicio" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                    <TextBlock Text="Especifique la hora en formato 24h (ej: 03:00)." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" Text="{Binding MaintenanceTime, Mode=TwoWay}" Height="28" VerticalAlignment="Center" Background="#0F172A" BorderBrush="#334155" Foreground="#F8FAFC" Padding="5,3"/>
                            </Grid>

                            <!-- Estado de la Próxima Ejecución -->
                            <Grid Margin="0,5,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Próxima Ejecución Programada:" FontSize="12.5" FontWeight="SemiBold" Foreground="#94A3B8"/>
                                <TextBlock Grid.Column="1" Text="{Binding MaintenanceNextRunText}" FontSize="12.5" FontWeight="Bold" Foreground="#10B981"/>
                            </Grid>

                            <!-- Guardar Configuración -->
                            <Button Content="Guardar y Aplicar Programación" Command="{Binding SaveMaintenanceCommand}" Style="{StaticResource ActionButton}" HorizontalAlignment="Stretch" Height="34" Padding="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- CARD 5: NOTIFICACIONES Y MONITOREO EN SEGUNDO PLANO -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Notificaciones y Bandeja del Sistema" FontSize="16" FontWeight="Bold" Foreground="#38BDF8" Margin="0,0,0,15"/>

                        <!-- Minimizar a la Bandeja -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Minimizar a la Bandeja del Sistema (System Tray)" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Al minimizar o cerrar la aplicación, permanecerá activa junto al reloj de Windows." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding MinimizeToTray, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,12"/>

                        <!-- Monitoreo Silencioso -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Monitoreo Silencioso de Hardware" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Supervisa de forma constante la memoria RAM, espacio libre y temperaturas en segundo plano." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding EnableBackgroundMonitoring, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,12"/>

                        <!-- Alerta RAM -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Notificación por Memoria RAM Elevada (> 85%)" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Muestra un aviso emergente cuando la memoria RAM esté saturada." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding NotifyHighRam, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,12"/>

                        <!-- Alerta Disco -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Notificación por Poco Espacio en Disco C: (&lt; 10 GB)" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Avisa cuando el disco principal tenga poco espacio disponible." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding NotifyLowDiskSpace, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,12"/>

                        <!-- Alerta Temperatura -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Notificación por Temperatura Crítica (> 80°C)" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Avisa si la CPU o GPU sobrepasan los límites seguros de temperatura." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding NotifyHighTemp, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CARD 6: ACTUALIZACIONES DE WINCLEANER -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Actualizaciones de WinCleaner" FontSize="16" FontWeight="Bold" Foreground="#10B981" Margin="0,0,0,15"/>

                        <!-- Comprobación automática -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Buscar actualizaciones automáticamente al iniciar" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="WinCleaner comprobará en GitHub si existe una versión más reciente cada vez que arranques la aplicación." FontSize="11" Foreground="#64748B" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding AutoCheckUpdates, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </Grid>

                        <Border Height="1" Background="#334155" Margin="0,0,0,15"/>

                        <!-- Estado y acciones de actualización -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding UpdateStatusText}" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <ProgressBar Height="4" Value="{Binding DownloadProgress}" Maximum="100" Margin="0,6,0,0"
                                             Style="{StaticResource ModernProgressBar}"
                                             Visibility="{Binding IsDownloadingUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="🔍 Buscar Actualizaciones"
                                    Style="{StaticResource SidebarButton}"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    IsEnabled="{Binding IsCheckingUpdates, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Padding="14,8" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Banner si hay actualización disponible -->
                        <Border Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Background="#0F172A" BorderBrush="#10B981" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="🚀 Nueva versión disponible:" FontSize="13" FontWeight="Bold" Foreground="#10B981"/>
                                    <TextBlock Text="{Binding LatestVersionText, StringFormat=' v{0}'}" FontSize="13" FontWeight="Bold" Foreground="#F8FAFC"/>
                                </StackPanel>

                                <ScrollViewer Grid.Row="1" MaxHeight="100" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                                    <TextBlock Text="{Binding ReleaseNotesText}" FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"/>
                                </ScrollViewer>

                                <Button Grid.Row="2" Content="⬇️ Descargar e Instalar Ahora"
                                        Style="{StaticResource ActionButton}"
                                        Command="{Binding InstallUpdateCommand}"
                                        Height="36" HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
