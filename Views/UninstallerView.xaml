<UserControl x:Class="WinCleaner.Views.UninstallerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             x:Name="UninstallerRoot">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Estilo de cabecera de columna -->
        <Style x:Key="ColumnHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Estilo fila de aplicación -->
        <Style x:Key="AppRowBorder" TargetType="Border">
            <Setter Property="Background" Value="#151F32"/>
            <Setter Property="BorderBrush" Value="#1E293B"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Cabecera -->
            <RowDefinition Height="Auto"/>   <!-- Barra de herramientas -->
            <RowDefinition Height="*"/>      <!-- Tabla -->
            <RowDefinition Height="Auto"/>   <!-- Pie de estado -->
        </Grid.RowDefinitions>

        <!-- ═══ CABECERA ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="Desinstalador Inteligente" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Desinstala programas Win32 y apps de la Tienda. WinCleaner busca residuos automáticamente."
                           FontSize="12" Foreground="#64748B" Margin="0,3,0,0"/>
            </StackPanel>
        </Grid>

        <!-- ═══ BARRA DE HERRAMIENTAS ═══ -->
        <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1"
                CornerRadius="12" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Búsqueda -->
                <Border Grid.Column="0" Background="#0B0F19" BorderBrush="#334155" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,14,0">
                    <Grid>
                        <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                              Fill="#475569" Width="14" Height="14" Stretch="Uniform" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" Foreground="#F8FAFC" BorderThickness="0"
                                 Padding="10,9" FontSize="13" VerticalAlignment="Center">
                            <TextBox.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="28,0,0,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="ph" Text="Buscar por nombre o editor..."
                                                               FontSize="13" Foreground="#475569" Margin="30,0,0,0"
                                                               VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="ph" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Filtros -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                    <CheckBox Content="Escritorio" IsChecked="{Binding ShowDesktopApps}"
                              Foreground="#94A3B8" FontSize="12" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <CheckBox Content="Store" IsChecked="{Binding ShowStoreApps}"
                              Foreground="#94A3B8" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Actualizar + loader -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource ActionButton}" Command="{Binding LoadAppsCommand}" Padding="18,8">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46C19.54 14.95 20 13.54 20 12c0-4.42-3.58-8-8-8zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74C4.46 9.05 4 10.46 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3z"
                                  Fill="White" Width="13" Height="13" Stretch="Uniform" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Actualizar" FontSize="12.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <ProgressBar Width="70" Height="5" Margin="12,0,0,0" IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ TABLA DE APLICACIONES CON PESTAÑAS ═══ -->
        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0" Padding="0">
            <TabControl.Resources>
                <!-- Estilo para TabControl (Contenedor de pestañas Segmentado / Pill) -->
                <Style TargetType="TabControl">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabControl">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Contenedor premium estilo Segmented Control de WinUI 3 -->
                                    <Border Grid.Row="0" 
                                            Background="#0B0F19" 
                                            BorderBrush="#1E293B" 
                                            BorderThickness="1" 
                                            CornerRadius="8" 
                                            Padding="3" 
                                            HorizontalAlignment="Left" 
                                            Margin="0,0,0,16">
                                        <TabPanel IsItemsHost="True" KeyboardNavigation.TabIndex="1"/>
                                    </Border>
                                    
                                    <!-- Contenido de la pestaña activa -->
                                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- Estilo para los TabItems dentro del contenedor segmented -->
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <TextBlock Text="{TemplateBinding Content}" 
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"
                                           FontSize="12.5" 
                                           FontWeight="SemiBold" 
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                    <Setter Property="Padding" Value="16,7"/>
                    <Setter Property="Margin" Value="0"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="#6366F1"/>
                                        <Setter Property="Foreground" Value="#FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- Pestaña 1: Aplicaciones Instaladas -->
            <TabItem Header="Aplicaciones Instaladas">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>   <!-- Cabecera de columnas -->
                                <RowDefinition Height="*"/>       <!-- Filas de datos -->
                            </Grid.RowDefinitions>

                            <!-- ─── Cabecera de columnas ─── -->
                            <Border Grid.Row="0" Background="#0B0F19" CornerRadius="12,12,0,0" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>    <!-- Selec. -->
                                        <ColumnDefinition Width="2*"/>    <!-- Nombre -->
                                        <ColumnDefinition Width="1.2*"/>  <!-- Editor -->
                                        <ColumnDefinition Width="80"/>    <!-- Tipo -->
                                        <ColumnDefinition Width="90"/>    <!-- Tamaño -->
                                        <ColumnDefinition Width="170"/>   <!-- Acción -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="SELEC." Style="{StaticResource ColumnHeaderStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="APLICACIÓN" Style="{StaticResource ColumnHeaderStyle}" Margin="4,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="EDITOR" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="TIPO" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="4" Text="TAMAÑO" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="5" Text="ACCIÓN" Style="{StaticResource ColumnHeaderStyle}" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- ─── Filas de datos ─── -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding FilteredApps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,9" BorderBrush="#1A2540" BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1A2D4A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="50"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="1.2*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="90"/>
                                                        <ColumnDefinition Width="170"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                                    <!-- Nombre -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0,10,0">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12.5" FontWeight="SemiBold"
                                                                   Foreground="#F1F5F9" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- Editor -->
                                                    <TextBlock Grid.Column="2" Text="{Binding Publisher}"
                                                               FontSize="11" Foreground="#64748B" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <!-- Tipo badge -->
                                                    <Border Grid.Column="3" CornerRadius="5" Padding="6,3" HorizontalAlignment="Left"
                                                            VerticalAlignment="Center">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUwp}" Value="True">
                                                                        <Setter Property="Background" Value="#1E1B4B"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsUwp}" Value="False">
                                                                        <Setter Property="Background" Value="#0F2233"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock FontSize="9" FontWeight="Bold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsUwp}" Value="True">
                                                                            <Setter Property="Text" Value="STORE"/>
                                                                            <Setter Property="Foreground" Value="#818CF8"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsUwp}" Value="False">
                                                                            <Setter Property="Text" Value="WIN32"/>
                                                                            <Setter Property="Foreground" Value="#38BDF8"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Border>

                                                    <!-- Tamaño -->
                                                    <TextBlock Grid.Column="4" Text="{Binding SizeText}"
                                                               FontSize="11.5" Foreground="#34D399" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>

                                                    <!-- Botón Desinstalar -->
                                                    <Button Grid.Column="5"
                                                            Command="{Binding DataContext.UninstallCommand, ElementName=UninstallerRoot}"
                                                            CommandParameter="{Binding}"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            Height="30" Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="bg" CornerRadius="6" Padding="14,0"
                                                                        Background="#3F0F0F" BorderBrush="#7F1D1D" BorderThickness="1">
                                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                                                                              Fill="#FCA5A5" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="Desinstalar" FontSize="11.5" FontWeight="Bold" Foreground="#FCA5A5"/>
                                                                    </StackPanel>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="bg" Property="Background" Value="#7F1D1D"/>
                                                                        <Setter TargetName="bg" Property="BorderBrush" Value="#EF4444"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="bg" Property="Background" Value="#991B1B"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Acciones inferiores para Apps -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="✓ Seleccionar Todo" Style="{StaticResource SidebarButton}" Command="{Binding ToggleAllAppsSelectionCommand}" CommandParameter="True" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="✗ Deseleccionar Todo" Style="{StaticResource SidebarButton}" Command="{Binding ToggleAllAppsSelectionCommand}" CommandParameter="False" Padding="12,6"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Desinstalar Seleccionadas (Lote)" Command="{Binding UninstallSelectedAppsCommand}" Height="36" Padding="20,0" Background="#EF4444" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Pestaña 2: Bloatware de Windows -->
            <TabItem Header="Bloatware de Windows">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Cabecera de columnas -->
                            <Border Grid.Row="0" Background="#0B0F19" CornerRadius="12,12,0,0" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SELEC." Style="{StaticResource ColumnHeaderStyle}" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="APLICACIÓN DE SISTEMA" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="2" Text="IDENTIFICADOR" Style="{StaticResource ColumnHeaderStyle}"/>
                                    <TextBlock Grid.Column="3" Text="TAMAÑO" Style="{StaticResource ColumnHeaderStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Filas de datos -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding BloatwareApps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,9" BorderBrush="#1A2540" BorderThickness="0,0,0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1A2D4A"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="2.5*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12.5" FontWeight="SemiBold" Foreground="#F1F5F9" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2" Text="{Binding Name}" FontSize="11.5" Foreground="#64748B" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding SizeText}" FontSize="11.5" Foreground="#34D399" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Acciones inferiores -->
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button Content="✓ Seleccionar Todo" Style="{StaticResource SidebarButton}" Command="{Binding ToggleAllBloatwareSelectionCommand}" CommandParameter="True" Padding="12,6" Margin="0,0,8,0"/>
                            <Button Content="✗ Deseleccionar Todo" Style="{StaticResource SidebarButton}" Command="{Binding ToggleAllBloatwareSelectionCommand}" CommandParameter="False" Padding="12,6"/>
                        </StackPanel>

                        <Button Grid.Column="2" Content="Desinstalar Bloatware Seleccionado" Command="{Binding UninstallSelectedBloatwareCommand}" Height="36" Padding="20,0" Background="#EF4444" Foreground="White" FontWeight="Bold" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ═══ PANEL DE RESIDUOS (overlay completo) ═══ -->
        <Border Grid.Row="2" Background="#1E293B" BorderBrush="#818CF8" BorderThickness="2"
                CornerRadius="12" Padding="20"
                Visibility="{Binding ShowResidualsCard, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="🧹 Residuos Detectados" FontSize="17" FontWeight="Bold" Foreground="#818CF8"/>
                    <TextBlock Text="Se encontraron elementos huérfanos del programa desinstalado. Selecciona los que deseas eliminar:"
                               FontSize="11.5" Foreground="#94A3B8" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>

                <Separator Grid.Row="1" Background="#334155" Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Residuals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1"
                                        CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Path}" FontSize="10.5" Foreground="#CBD5E1" TextTrimming="CharacterEllipsis">
                                                <TextBlock.ToolTip><ToolTip Content="{Binding Path}"/></TextBlock.ToolTip>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                <Border Background="#312E81" CornerRadius="3" Padding="5,1" Margin="0,0,6,0">
                                                    <TextBlock Text="{Binding Type}" FontSize="8.5" FontWeight="Bold" Foreground="#818CF8"/>
                                                </Border>
                                                <TextBlock Text="{Binding SizeText, StringFormat='Tamaño: {0}'}" FontSize="9" Foreground="#475569"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                    <Button Content="🗑️  Limpiar Residuos Seleccionados" Style="{StaticResource ActionButton}"
                            Command="{Binding CleanResidualsCommand}" Height="40" Margin="0,0,0,8"/>
                    <Button Content="Omitir y continuar" Command="{Binding CloseResidualsCardCommand}" Height="36">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#64748B"/>
                                <Setter Property="BorderBrush" Value="#334155"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border CornerRadius="8" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#334155"/>
                                                    <Setter Property="Foreground" Value="#F8FAFC"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ PIE DE ESTADO ═══ -->
        <Border Grid.Row="3" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0"
                Padding="12,10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
