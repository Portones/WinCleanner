<UserControl x:Class="WinCleaner.Views.Controls.HistoryChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="600">

    <Grid Background="Transparent">
        <!-- ÁREA DE BARRAS DE LA GRÁFICA -->
        <ItemsControl ItemsSource="{Binding Bars}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Tamaño Liberado encima de la barra -->
                        <TextBlock Grid.Row="0" Text="{Binding FormattedSize}" FontSize="9.5" FontWeight="SemiBold"
                                   Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,4"/>

                        <!-- Contenedor de la barra alineado al fondo -->
                        <Border Grid.Row="1" VerticalAlignment="Bottom" Height="140" Width="28" Background="#0F172A" CornerRadius="6" Padding="2" ToolTip="{Binding ToolTipText}">
                            <Border VerticalAlignment="Bottom" Height="{Binding HeightValue}" Width="24" CornerRadius="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#818CF8" Offset="0"/>
                                        <GradientStop Color="#4F46E5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>

                        <!-- Fecha debajo de la barra -->
                        <TextBlock Grid.Row="2" Text="{Binding DateLabel}" FontSize="10" FontWeight="Bold"
                                   Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>
