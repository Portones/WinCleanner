<UserControl x:Class="WinCleaner.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="680" d:DesignWidth="1000">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Recommendations -->
            <RowDefinition Height="*"/>      <!-- Cards Grid -->
        </Grid.RowDefinitions>

        <!-- ═══ CABECERA ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Panel de Control" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="Último análisis: " FontSize="12" Foreground="#64748B"/>
                    <TextBlock Text="{Binding LastScanTimeText}" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock Text="  ·  Uptime: " FontSize="12" Foreground="#64748B"/>
                    <TextBlock Text="{Binding Uptime}" FontSize="12" Foreground="#94A3B8" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📊 Generar Reporte" Command="{Binding GenerateReportCommand}" Style="{StaticResource SidebarButton}" Height="34" Padding="14,0" Margin="0,0,12,0"/>
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1"
                        CornerRadius="20" Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="9" Height="9" Fill="{Binding HealthColor, FallbackValue=#10B981}"
                                 Margin="0,0,8,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Ellipse.RenderTransform>
                        <Ellipse.Triggers>
                            <EventTrigger RoutedEvent="Ellipse.Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.2" To="1.0" Duration="0:0:0.9"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" From="0.7" To="1.5" Duration="0:0:0.9"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" From="0.7" To="1.5" Duration="0:0:0.9"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </Ellipse.Triggers>
                    </Ellipse>
                    <TextBlock Text="Salud: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding OverallHealth}" FontSize="12.5" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
        </Grid>

        <!-- ═══ RECOMENDACIONES ═══ -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Recommendations}" Margin="0,0,0,12">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1E293B" BorderBrush="{Binding ColorHex}" BorderThickness="1"
                            CornerRadius="8" Padding="12,8" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Path Grid.Column="0" Data="{Binding IconPathData}" Fill="{Binding ColorHex}"
                                  Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="4,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="{Binding Text}" FontSize="12" Foreground="#F8FAFC"
                                       FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            <Button Grid.Column="2" Content="{Binding ActionText}" Margin="15,0,4,0"
                                    Padding="14,4" Height="26" FontSize="10.5"
                                    Command="{Binding DataContext.ExecuteRecommendationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                        <Setter Property="Background" Value="{Binding ColorHex}"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ═══ GRID DE TARJETAS: 3 columnas x 2 filas ═══ -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════ -->
            <!-- TARJETA CPU -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="0" Background="#1E293B" BorderBrush="#334155"
                    BorderThickness="1" CornerRadius="14" Margin="0,0,6,6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#2D1F5E" CornerRadius="8" Padding="6" Margin="0,0,10,0">
                                <Path Data="M19,15h2v-2h-2V11h2V9h-2V7h-2V5h-2V3h-2v2H11V3H9v2H7V3H5v2H3v2h2v2H3v2h2v2H3v2h2v2h2v2h2v2h2v-2h2v2h2v-2h2v-2h-2v-2 M7,7h10v10H7V7z"
                                      Fill="#818CF8" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="PROCESADOR" FontSize="9" FontWeight="Bold" Foreground="#4F46E5"/>
                                <TextBlock Text="CPU" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding CpuTemp}" FontSize="11" Foreground="#94A3B8"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Gráfica de Progreso Circular -->
                    <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10">
                        <Grid Width="110" Height="110">
                            <!-- Círculo de fondo -->
                            <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                            <!-- Progreso circular coloreado -->
                            <Ellipse Stroke="#6366F1" StrokeThickness="9" Width="100" Height="100"
                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.StrokeDashArray>
                                    <Binding Path="CpuUsage" Converter="{StaticResource CircularProgressConverter}" ConverterParameter="100"/>
                                </Ellipse.StrokeDashArray>
                            </Ellipse>
                            <!-- Texto central -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CpuUsage, StringFormat='{}{0:F0}%'}" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                                <TextBlock Text="Uso" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Funcionamiento estable del procesador" FontSize="10.5" Foreground="#64748B" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════ -->
            <!-- TARJETA RAM -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="1" Background="#1E293B" BorderBrush="#334155"
                    BorderThickness="1" CornerRadius="14" Margin="6,0,6,6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#0F2A1A" CornerRadius="8" Padding="6" Margin="0,0,10,0">
                                <Path Data="M21,16V8a2,2,0,0,0-2-2H17V3H15v3H13V3H11v3H9V3H7v3H5A2,2,0,0,0,3,8v8a2,2,0,0,0,2,2H7v3H9v-3H11v3H13v-3H15v3H17v-3h2A2,2,0,0,0,21,16ZM19,16H5V8H19v8Z"
                                      Fill="#10B981" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="MEMORIA" FontSize="9" FontWeight="Bold" Foreground="#059669"/>
                                <TextBlock Text="RAM" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                            </StackPanel>
                        </StackPanel>
                        <Border Background="#334155" CornerRadius="10" Width="20" Height="20"
                                HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Help">
                            <Border.ToolTip>
                                <ToolTip Background="#0F172A" BorderBrush="#334155" Foreground="#F8FAFC" Padding="12">
                                    <StackPanel Width="280">
                                        <TextBlock Text="RAM Física: Memoria en uso por apps ahora mismo." FontSize="11" Foreground="#CBD5E1" Margin="0,0,0,6" TextWrapping="Wrap"/>
                                        <TextBlock Text="Comprometida: RAM + página virtual reservada." FontSize="11" Foreground="#CBD5E1" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#94A3B8"/>
                        </Border>
                    </Grid>

                    <!-- Gráfica de Progreso Circular -->
                    <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10">
                        <Grid Width="110" Height="110">
                            <!-- Círculo de fondo -->
                            <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                            <!-- Progreso circular coloreado -->
                            <Ellipse Stroke="#10B981" StrokeThickness="9" Width="100" Height="100"
                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.StrokeDashArray>
                                    <Binding Path="Ram.UsagePercentage" Converter="{StaticResource CircularProgressConverter}" ConverterParameter="100"/>
                                </Ellipse.StrokeDashArray>
                            </Ellipse>
                            <!-- Texto central -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Ram.UsagePercentage, StringFormat='{}{0:F0}%'}" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                                <TextBlock Text="Uso" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Button Grid.Row="2" Command="{Binding OptimizeRamCommand}" IsEnabled="{Binding CanOptimizeRam}" Height="34">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                <Setter Property="Background" Value="#065F46"/>
                                <Setter Property="BorderBrush" Value="#10B981"/>
                                <Setter Property="Padding" Value="10,0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="BorderBrush" Value="#334155"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M12 2v2.18C9.91 3.46 8 4.83 8 7.5 8 10 10 12 12 12s4-2 4-4.5C16 4.83 14.09 3.46 12 4.18V2z"
                                  Fill="White" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Optimizar RAM" FontSize="11.5" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════ -->
            <!-- TARJETA GPU -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="0" Grid.Column="2" Background="#1E293B" BorderBrush="#334155"
                    BorderThickness="1" CornerRadius="14" Margin="6,0,0,6" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#1A1A0A" CornerRadius="8" Padding="6" Margin="0,0,10,0">
                                <Path Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7l-2 3v1h8v-1l-2-3h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H3V4h18v12z"
                                      Fill="#EAB308" Width="14" Height="14" Stretch="Uniform"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="GRÁFICOS" FontSize="9" FontWeight="Bold" Foreground="#CA8A04"/>
                                <TextBlock Text="GPU" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Gráfica de Progreso Circular (VRAM o indicador activo) -->
                    <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,10">
                        <Grid Width="110" Height="110">
                            <!-- Círculo de fondo -->
                            <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                            <!-- Progreso circular coloreado (VRAM) -->
                            <Ellipse Stroke="#EAB308" StrokeThickness="9" Width="100" Height="100"
                                     StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform Angle="-90"/>
                                </Ellipse.RenderTransform>
                                <Ellipse.StrokeDashArray>
                                    <!-- Dado que WMI no da el % dinámico, mostramos un 100% estático/activo o 0 según se requiera. Usamos 100% para indicar activa -->
                                    <DoubleCollection>314.16, 314.16</DoubleCollection>
                                </Ellipse.StrokeDashArray>
                            </Ellipse>
                            <!-- Texto central -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Path Data="M21 2H3c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h7l-2 3v1h8v-1l-2-3h7c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-2 10H5V6h14v6z"
                                      Fill="#EAB308" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center"/>
                                <TextBlock Text="ACTIVA" FontSize="9.5" FontWeight="Bold" Foreground="#FDE047" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Nombre de GPU y VRAM -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <ItemsControl ItemsSource="{Binding Gpus}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#94A3B8"
                                               FontWeight="SemiBold" TextAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════ -->
            <!-- TARJETA ALMACENAMIENTO (C:) CON ANILLO + LISTA -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#1E293B" BorderBrush="#334155"
                    BorderThickness="1" CornerRadius="14" Margin="0,6,6,0" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#0A1E38" CornerRadius="8" Padding="6" Margin="0,0,10,0">
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm0-12c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4z"
                                  Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="ALMACENAMIENTO" FontSize="9" FontWeight="Bold" Foreground="#1D4ED8"/>
                            <TextBlock Text="Unidades de Disco" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Panel Dividido: Anillo C: a la izquierda, lista de discos a la derecha -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Anillo del disco principal (C: o primer disco) -->
                        <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Grid Width="110" Height="110">
                                <Ellipse Stroke="#152033" StrokeThickness="9" Width="100" Height="100"/>
                                <Ellipse Stroke="#3B82F6" StrokeThickness="9" Width="100" Height="100"
                                         StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform Angle="-90"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.StrokeDashArray>
                                        <!-- Enlazado al UsedPercentage del primer disco -->
                                        <Binding Path="Disks[0].UsedPercentage" Converter="{StaticResource CircularProgressConverter}" ConverterParameter="100"/>
                                    </Ellipse.StrokeDashArray>
                                </Ellipse>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Disks[0].UsedPercentage, StringFormat='{}{0:F0}%'}" FontSize="22" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Lleno" FontSize="9" Foreground="#64748B" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <!-- Lista detallada compacta a la derecha -->
                        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Disks}" Margin="10,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#0F1A2E" BorderBrush="#1E3A5F" BorderThickness="1"
                                                CornerRadius="10" Padding="12,8" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Border Grid.Column="0" Background="#1E3A5F" CornerRadius="6" Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DriveLetter}" FontSize="12.5" FontWeight="Bold" Foreground="#60A5FA"/>
                                                </Border>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding VolumeLabel, TargetNullValue='Disco Local'}" FontSize="11.5" Foreground="#94A3B8" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="9.5" Foreground="#64748B"/>
                                                </StackPanel>

                                                <Border Grid.Column="2" Background="#065F46" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding SmartStatus}" FontSize="9" FontWeight="Bold" Foreground="#34D399"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════ -->
            <!-- TARJETA HISTORIAL DE LIMPIEZAS -->
            <!-- ═══════════════════════════════════════ -->
            <Border Grid.Row="1" Grid.Column="2" Background="#1E293B" BorderBrush="#334155"
                    BorderThickness="1" CornerRadius="14" Margin="6,6,0,0" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#1A1525" CornerRadius="8" Padding="6" Margin="0,0,10,0">
                            <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"
                                  Fill="#A78BFA" Width="14" Height="14" Stretch="Uniform"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="HISTORIAL" FontSize="9" FontWeight="Bold" Foreground="#7C3AED"/>
                            <TextBlock Text="Espacio Liberado" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Row="1" Background="#0F172A" CornerRadius="10" Padding="12,10" Margin="0,4,0,10" BorderThickness="1" BorderBrush="#334155">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="TOTAL RECUPERADO" FontSize="8.5" FontWeight="Bold" Foreground="#94A3B8"/>
                                <TextBlock Text="{Binding TotalBytesCleanedText}" FontSize="20" FontWeight="Bold" Foreground="#A78BFA" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Path Grid.Column="1" Data="M19.36 10.04C18.61 6.56 15.5 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.64-4.96zM19 18H6c-2.21 0-4-1.79-4-4 0-2.05 1.53-3.76 3.56-3.97l1.07-.11.5-.95C8.08 7.14 9.94 6 12 6c2.62 0 4.88 1.86 5.39 4.43l.3 1.5 1.53.11c1.56.1 2.78 1.41 2.78 2.96 0 1.65-1.35 3-3 3z"
                                  Fill="#7C3AED" Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Últimas limpiezas:" FontSize="10.5" FontWeight="SemiBold" Foreground="#64748B" Margin="0,0,0,6"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding RecentCleanups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#334155" BorderThickness="0,0,0,1" Padding="0,6" Margin="0,0,0,4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DateText}" FontSize="10.5" Foreground="#94A3B8" FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding ItemsCount, StringFormat='{}{0} elementos limpios'}" FontSize="9" Foreground="#64748B"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding SizeText}" FontSize="11.5" FontWeight="Bold" Foreground="#34D399" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
