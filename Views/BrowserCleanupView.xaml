<UserControl x:Class="WinCleaner.Views.BrowserCleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:BrowserCleanupViewModel}"
             d:DesignHeight="600" d:DesignWidth="850">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- TabControl oscuro — mismo patrón que PhotosCleanupView -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{TemplateBinding Content}" FontSize="13.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="6" Padding="15,10" Margin="0,0,8,0" Cursor="Hand">
                            <ContentPresenter x:Name="contentPresenter" ContentSource="Header" Focusable="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#312E81"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#4F46E5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="🌐 Limpieza Avanzada" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Limpieza de caché de navegadores web y registros de eventos del sistema Windows." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- CONTENIDO PRINCIPAL -->
        <TabControl Grid.Row="1" SelectedIndex="{Binding ActiveTab}">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- PESTAÑA 1: CACHÉ DE NAVEGADORES                       -->
            <!-- ══════════════════════════════════════════════════════ -->
            <TabItem Header="🌐  Caché de Navegadores">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de acciones -->
                    <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Navegadores soportados" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Chrome · Edge · Firefox · Brave · Opera · Vivaldi" FontSize="11" Foreground="#64748B" Margin="0,3,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="🔍  Escanear"
                                    Style="{StaticResource SidebarButton}"
                                    Command="{Binding ScanCommand}"
                                    Margin="0,0,8,0"/>

                            <Button Grid.Column="2" Content="🧹  Limpiar Todo"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding CleanCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Estado y progreso -->
                    <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding ScanStatus}" Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding CleanProgress}" Maximum="100" Height="6"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource ModernProgressBar}"
                                         Visibility="{Binding IsCleaning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Lista de perfiles encontrados -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BrowserProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E293B" CornerRadius="8"
                                            BorderBrush="#334155" BorderThickness="1"
                                            Padding="14,12" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BrowserName}"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                                <TextBlock Text="{Binding ProfilePath}"
                                                           FontSize="10" Foreground="#64748B"
                                                           TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="1" Background="#0F172A" CornerRadius="6"
                                                    Padding="12,5" VerticalAlignment="Center">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#F59E0B">
                                                    <TextBlock.Text>
                                                        <Binding Path="CacheSizeBytes"
                                                                 Converter="{StaticResource BytesToSizeConverter}"
                                                                 FallbackValue="0 B"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- PESTAÑA 2: REGISTROS DE EVENTOS                       -->
            <!-- ══════════════════════════════════════════════════════ -->
            <TabItem Header="📋  Registros de Eventos">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de acciones -->
                    <Border Grid.Row="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="✅  Seleccionar Todo"
                                    Style="{StaticResource SidebarButton}"
                                    Command="{Binding SelectAllLogsCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="☐  Ninguno"
                                    Style="{StaticResource SidebarButton}"
                                    Command="{Binding DeselectAllLogsCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="🔄  Cargar Registros"
                                    Style="{StaticResource SidebarButton}"
                                    Command="{Binding LoadLogsCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="🗑️  Vaciar Seleccionados"
                                    Style="{StaticResource ActionButton}"
                                    Command="{Binding ClearLogsCommand}"/>
                        </StackPanel>
                    </Border>

                    <!-- Estado y progreso -->
                    <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding LogStatus}" Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding LogProgress}" Maximum="100" Height="6"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource ModernProgressBar}"
                                         Visibility="{Binding IsClearingLogs, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Lista de registros -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E293B" CornerRadius="8"
                                            BorderBrush="#334155" BorderThickness="1"
                                            Padding="14,12" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,14,0"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding LogName}"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                                <TextBlock FontSize="11" Foreground="#64748B" Margin="0,3,0,0">
                                                    <Run Text="{Binding EntryCount, StringFormat={}{0:N0} entradas}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#0F172A" CornerRadius="6"
                                                    Padding="12,5" VerticalAlignment="Center">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#F59E0B">
                                                    <TextBlock.Text>
                                                        <Binding Path="SizeBytes"
                                                                 Converter="{StaticResource BytesToSizeConverter}"
                                                                 FallbackValue="0 B"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
