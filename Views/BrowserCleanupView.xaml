<UserControl x:Class="WinCleaner.Views.BrowserCleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:BrowserCleanupViewModel}"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="🌐 Limpieza Avanzada" FontSize="24" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Limpieza de caché de navegadores y registros de eventos del sistema" FontSize="13" Foreground="#94A3B8" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- TABS -->
        <TabControl Grid.Row="1" Grid.RowSpan="2"
                    Background="Transparent"
                    BorderBrush="#1E293B"
                    SelectedIndex="{Binding ActiveTab}">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#94A3B8"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Padding" Value="18,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="tab" Background="Transparent"
                                        BorderBrush="Transparent" BorderThickness="0,0,0,2"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="tab" Property="BorderBrush" Value="#6366F1"/>
                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#CBD5E1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- PESTAÑA 1: LIMPIADOR DE NAVEGADORES                                -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <TabItem Header="🌐  Caché de Navegadores">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de acciones -->
                    <Border Grid.Row="0" Background="#0F172A" CornerRadius="12" Padding="20,14" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Navegadores Soportados" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Chrome · Edge · Firefox · Brave · Opera · Vivaldi" FontSize="11" Foreground="#64748B" Margin="0,3,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1" Content="🔍  Escanear"
                                    Command="{Binding ScanCommand}"
                                    Margin="0,0,10,0" Padding="18,10"
                                    Background="#1E3A5F" Foreground="#60A5FA"
                                    BorderBrush="#2563EB" BorderThickness="1"
                                    FontWeight="SemiBold" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                        <Setter Property="Foreground" Value="#60A5FA"/>
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="18,10"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2563EB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button Grid.Column="2" Content="🧹  Limpiar Todo"
                                    Command="{Binding CleanCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2D1B4E"/>
                                        <Setter Property="Foreground" Value="#A78BFA"/>
                                        <Setter Property="BorderBrush" Value="#7C3AED"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="18,10"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#7C3AED"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Estado y progreso -->
                    <Border Grid.Row="1" Background="#0F172A" CornerRadius="10" Padding="16,12" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding ScanStatus}" Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding CleanProgress}" Maximum="100" Height="4"
                                         Margin="0,8,0,0" Background="#1E293B" Foreground="#6366F1"
                                         Visibility="{Binding IsCleaning, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Lista de perfiles encontrados -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding BrowserProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A" CornerRadius="10"
                                            BorderBrush="#1E293B" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding BrowserName}"
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                                <TextBlock Text="{Binding ProfilePath}"
                                                           FontSize="10" Foreground="#64748B"
                                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="#1E293B" CornerRadius="6"
                                                    Padding="12,6" VerticalAlignment="Center">
                                                <TextBlock FontSize="13" FontWeight="Bold" Foreground="#F59E0B">
                                                    <TextBlock.Text>
                                                        <Binding Path="CacheSizeBytes"
                                                                 Converter="{StaticResource BytesToSizeConverter}"
                                                                 FallbackValue="0 B"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════════════════════════ -->
            <!-- PESTAÑA 2: REGISTROS DE EVENTOS                                    -->
            <!-- ══════════════════════════════════════════════════════════════════ -->
            <TabItem Header="📋  Registros de Eventos">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de acciones -->
                    <Border Grid.Row="0" Background="#0F172A" CornerRadius="12" Padding="20,14" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="✅  Seleccionar Todo"
                                    Command="{Binding SelectAllLogsCommand}"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#0F2A1A"/>
                                        <Setter Property="Foreground" Value="#34D399"/>
                                        <Setter Property="BorderBrush" Value="#059669"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="14,9"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="☐  Deseleccionar Todo"
                                    Command="{Binding DeselectAllLogsCommand}"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1E293B"/>
                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                        <Setter Property="BorderBrush" Value="#334155"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="14,9"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="🔄  Cargar Registros"
                                    Command="{Binding LoadLogsCommand}"
                                    Margin="0,0,8,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                        <Setter Property="Foreground" Value="#60A5FA"/>
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="14,9"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#2563EB"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="🗑️  Vaciar Seleccionados"
                                    Command="{Binding ClearLogsCommand}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#3B1212"/>
                                        <Setter Property="Foreground" Value="#F87171"/>
                                        <Setter Property="BorderBrush" Value="#DC2626"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Padding" Value="14,9"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="7" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#DC2626"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Estado y progreso -->
                    <Border Grid.Row="1" Background="#0F172A" CornerRadius="10" Padding="16,12" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{Binding LogStatus}" Foreground="#94A3B8" FontSize="12" TextWrapping="Wrap"/>
                            <ProgressBar Value="{Binding LogProgress}" Maximum="100" Height="4"
                                         Margin="0,8,0,0" Background="#1E293B" Foreground="#EF4444"
                                         Visibility="{Binding IsClearingLogs, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Lista de registros -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding EventLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A" CornerRadius="10"
                                            BorderBrush="#1E293B" BorderThickness="1"
                                            Padding="16,14" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                      VerticalAlignment="Center" Margin="0,0,14,0"/>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding LogName}"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                                <TextBlock FontSize="11" Foreground="#64748B" Margin="0,3,0,0">
                                                    <Run Text="{Binding EntryCount, StringFormat={}{0:N0} entradas}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <Border Grid.Column="2" Background="#1E293B" CornerRadius="6"
                                                    Padding="10,5" Margin="10,0" VerticalAlignment="Center">
                                                <TextBlock FontSize="12" FontWeight="Bold" Foreground="#F59E0B">
                                                    <TextBlock.Text>
                                                        <Binding Path="SizeBytes"
                                                                 Converter="{StaticResource BytesToSizeConverter}"
                                                                 FallbackValue="0 B"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
