<UserControl x:Class="WinCleaner.Views.Categories.CleanupCategoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             xmlns:catVm="clr-namespace:WinCleaner.ViewModels.Categories"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance catVm:CleanupCategoryViewModel}"
             d:DesignHeight="650" d:DesignWidth="900">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type vm:CleanupViewModel}">
            <local:CleanupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DuplicateFilesViewModel}">
            <local:DuplicateFilesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PhotosCleanupViewModel}">
            <local:PhotosCleanupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BrowserCleanupViewModel}">
            <local:BrowserCleanupView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CleanupHistoryViewModel}">
            <local:CleanupHistoryView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="5">
        <TabControl Style="{StaticResource ModernCategoryTabControl}">
            <TabItem Header="🧹 Limpieza Avanzada" Content="{Binding CleanupViewModel}"/>
            <TabItem Header="📑 Archivos Duplicados" Content="{Binding DuplicateFilesViewModel}"/>
            <TabItem Header="🖼️ Limpiador de Fotos" Content="{Binding PhotosCleanupViewModel}"/>
            <TabItem Header="🌐 Navegadores y Logs" Content="{Binding BrowserCleanupViewModel}"/>
            <TabItem Header="📊 Historial Gráfico" Content="{Binding CleanupHistoryViewModel}"/>
        </TabControl>
    </Grid>
</UserControl>
