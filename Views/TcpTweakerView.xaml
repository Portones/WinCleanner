<UserControl x:Class="WinCleaner.Views.TcpTweakerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:TcpTweakerViewModel}"
             d:DesignHeight="650" d:DesignWidth="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="⚡ Optimizador de Red TCP/IP (TCP Tweaker)" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
            <TextBlock Text="Ajusta los parámetros de red nativos de Windows para minimizar el ping en juegos en línea y maximizar el rendimiento del ancho de banda." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- BARRA DE ESTADO Y ACCIONES -->
        <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="🔄 Recargar Estado" Command="{Binding LoadStateCommand}" Style="{StaticResource SidebarButton}" Margin="0,0,10,0"/>
                    <Button Content="⚡ Aplicar Ajustes Recomendados" Command="{Binding ApplyRecommendedCommand}" Style="{StaticResource ActionButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CARDS DE OPCIONES TCP/IP -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- CARD 1: ALGORITMO DE NAGLE -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎮 Algoritmo de Nagle (Deshabilitar para Gaming)" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                                <Border Background="#0F172A" BorderBrush="#10B981" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Baja Latencia / Ping" FontSize="10" FontWeight="Bold" Foreground="#10B981"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Desactiva la acumulación de paquetes pequeños TCP (TCPNoDelay y TcpAckFrequency = 1), enviando datos inmediatamente para reducir la latencia en juegos online como Valorant, CS2 o LoL."
                                       FontSize="12" Foreground="#94A3B8" Margin="0,5,20,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding ToggleNagleCommand}"
                                VerticalAlignment="Center"
                                Padding="16,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNagleDisabled}" Value="True">
                                            <Setter Property="Background" Value="#10B981"/>
                                            <Setter Property="Content" Value="✓ Deshabilitado (Optimizado)"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNagleDisabled}" Value="False">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="Content" Value="Habilitado (Por Defecto)"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- CARD 2: TCP AUTO-TUNING -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐 Auto-Tuning de Ventana de Recepción TCP" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                                <Border Background="#0F172A" BorderBrush="#6366F1" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Ancho de Banda" FontSize="10" FontWeight="Bold" Foreground="#A5B4FC"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Ajusta dinámicamente el tamaño de la ventana de recepción TCP según la velocidad de tu conexión a internet para maximizar descargas y streaming."
                                       FontSize="12" Foreground="#94A3B8" Margin="0,5,20,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding ToggleAutoTuningCommand}"
                                VerticalAlignment="Center"
                                Padding="16,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAutoTuningEnabled}" Value="True">
                                            <Setter Property="Background" Value="#10B981"/>
                                            <Setter Property="Content" Value="✓ Activado (Normal)"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsAutoTuningEnabled}" Value="False">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="Content" Value="Desactivado"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- CARD 3: TCP CHIMNEY OFFLOAD -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚀 TCP Chimney Offload" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                                <Border Background="#0F172A" BorderBrush="#8B5CF6" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Descarga de CPU" FontSize="10" FontWeight="Bold" Foreground="#C4B5FD"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="Transfiere el procesamiento del tráfico de red directamente a la tarjeta de red (NIC), reduciendo la carga del procesador en transferencias pesadas."
                                       FontSize="12" Foreground="#94A3B8" Margin="0,5,20,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Command="{Binding ToggleChimneyCommand}"
                                VerticalAlignment="Center"
                                Padding="16,8">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsChimneyOffloadEnabled}" Value="True">
                                            <Setter Property="Background" Value="#10B981"/>
                                            <Setter Property="Content" Value="✓ Activado"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsChimneyOffloadEnabled}" Value="False">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Setter Property="Content" Value="Desactivado"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
