<UserControl x:Class="WinCleaner.Views.StartupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Registro del Conversor Booleano a Visibilidad de WPF -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Dashboard de Arranque -->
            <RowDefinition Height="Auto"/>
            <!-- Sugerencia Inteligente -->
            <RowDefinition Height="Auto"/>
            <!-- Panel de Acciones Rápidas -->
            <RowDefinition Height="Auto"/>
            <!-- Lista de Programas de Inicio -->
            <RowDefinition Height="*"/>
            <!-- Pie de Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Gestión de Aplicaciones de Inicio" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Controle las aplicaciones que se inician automáticamente al encender su equipo. Desactive elementos para acelerar el arranque." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- DASHBOARD DE ARRANQUE -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Tarjeta 1: Tiempo de Arranque -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="M22 5.72l-4.6-3.86-1.29 1.53 4.6 3.86L22 5.72zM7.88 3.39L6.6 1.86 2 5.71l1.29 1.53 4.59-3.85zM12.5 8H11v6l4.75 2.85.75-1.23-4-2.37V8zM12 4c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 16c-3.86 0-7-3.14-7-7s3.14-7 7-7 7 3.14 7 7-3.14 7-7 7z" Fill="#6366F1" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Tiempo de Arranque" FontSize="13.5" FontWeight="Bold" Foreground="#F8FAFC"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding LastBootDurationText}" FontSize="32" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="{Binding BootStatusText}" FontSize="11" FontWeight="Bold" Foreground="{Binding BootStatusColor}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tarjeta 2: Tiempo de Actividad (Uptime) -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z" Fill="#10B981" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Tiempo de Actividad" FontSize="13.5" FontWeight="Bold" Foreground="#F8FAFC"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding UptimeText}" FontSize="32" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="{Binding LastBootTimeText, StringFormat={}Encendido: {0}}" FontSize="11" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tarjeta 3: Historial de Arranques -->
            <Border Grid.Column="4" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z" Fill="#8B5CF6" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Historial de Arranques" FontSize="13.5" FontWeight="Bold" Foreground="#F8FAFC"/>
                    </StackPanel>

                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <ItemsControl ItemsSource="{Binding BootHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DateText}" FontSize="11.5" Foreground="#94A3B8"/>
                                        <TextBlock Grid.Column="1" Text="{Binding DurationText}" FontSize="11.5" FontWeight="Bold" Foreground="#8B5CF6"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ALERTA DE SUGERENCIA INTELIGENTE CONTEXTUAL -->
        <Border Grid.Row="2" Background="#1E293B" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15"
                Visibility="{Binding HasStartupSuggestions, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StartupSuggestionText}" FontSize="12.5" FontWeight="SemiBold" Foreground="#F8FAFC" TextWrapping="Wrap" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Optimizar Inicio" Style="{StaticResource ActionButton}" Command="{Binding DisableRecommendedCommand}" Height="30" Padding="15,0" Margin="15,0,0,0" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- PANEL DE ACCIONES RÁPIDAS -->
        <Border Grid.Row="3" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Recargar Lista" Style="{StaticResource ActionButton}" Command="{Binding LoadAppsCommand}" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Escaneando el registro y carpetas de inicio de Windows..." FontSize="11" Foreground="#94A3B8"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ordenar por:" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox Style="{StaticResource ModernComboBox}" SelectedValuePath="Content" SelectedValue="{Binding SelectedSortOption, Mode=TwoWay}" Width="240" Height="32">
                        <ComboBoxItem Content="Estado (Habilitados primero)"/>
                        <ComboBoxItem Content="Estado (Deshabilitados primero)"/>
                        <ComboBoxItem Content="Nombre"/>
                        <ComboBoxItem Content="Impacto"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LISTA DE APLICACIONES DE INICIO -->
        <ListView Grid.Row="4" ItemsSource="{Binding StartupApps}" Style="{StaticResource ModernListView}" ItemContainerStyle="{StaticResource ModernListViewItem}">
            <ListView.View>
                <GridView>
                    <!-- Columna de Estado (Activar/Desactivar) -->
                    <GridViewColumn Header="Inicio" Width="60">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsEnabled, Mode=OneWay}" 
                                          Command="{Binding DataContext.ToggleAppCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                          CommandParameter="{Binding}"
                                          HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Nombre de Aplicación -->
                    <GridViewColumn Header="Aplicación" Width="180">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#F8FAFC" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Origen/Ubicación -->
                    <GridViewColumn Header="Ubicación" Width="150">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Location}" FontSize="11" Foreground="#818CF8" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Impacto de Inicio -->
                    <GridViewColumn Header="Impacto" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A" BorderBrush="{Binding ImpactColor}" BorderThickness="1" CornerRadius="6" Padding="8,3" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding Impact}" FontSize="9.5" FontWeight="Bold" Foreground="{Binding ImpactColor}" TextAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Comando ejecutado -->
                    <GridViewColumn Header="Comando de Ejecución" Width="330">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Command}" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="{Binding Command}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="5" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
