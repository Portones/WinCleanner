<UserControl x:Class="WinCleaner.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Estilo premium para simular un ToggleSwitch de CheckBox -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="10,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Grid Width="44" Height="22">
                                    <Border x:Name="BackgroundBorder" Background="#334155" CornerRadius="11" BorderThickness="0" SnapsToDevicePixels="True"/>
                                    <Border x:Name="ThumbBorder" HorizontalAlignment="Left" Width="18" Height="18" Margin="2" Background="#F8FAFC" CornerRadius="9" SnapsToDevicePixels="True">
                                        <Border.RenderTransform>
                                            <TranslateTransform X="0" Y="0"/>
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" HorizontalAlignment="Left" RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="BackgroundBorder" Property="Background" Value="#6366F1"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="22" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernListView" TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
        </Style>

        <Style x:Key="ModernListViewItem" TargetType="ListViewItem">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="#334155" BorderThickness="1" Padding="{TemplateBinding Padding}">
                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{Binding Path=View.Columns, RelativeSource={RelativeSource AncestorType=ListView}}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1E1E38"/>
                                <Setter Property="BorderBrush" Value="#4F46E5"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Background" Value="#2D3748"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Contenido Split -->
            <RowDefinition Height="*"/>
            <!-- Pie de Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Rendimiento y Optimización de Red" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Ajuste las directivas del sistema para mejorar su privacidad, optimice el consumo de recursos al jugar y seleccione los servidores DNS más veloces." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- CONTENIDO SPLIT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Optimización de Sistema / Modo Juego -->
                <ColumnDefinition Width="340"/>
                <!-- Espaciador -->
                <ColumnDefinition Width="15"/>
                <!-- DNS Speed Test -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA 0: OPTIMIZACIÓN DE SISTEMA & MODO JUEGO -->
            <StackPanel Grid.Column="0">
                <!-- TARJETA 1: WINDOWS DEBLOATER (PRIVACIDAD) -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Privacidad y Telemetría" FontSize="16" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="Desactive servicios de recolección de datos innecesarios:" FontSize="11" Foreground="#94A3B8" Margin="0,4,0,15"/>

                        <!-- Switch Telemetría -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Desactivar Telemetría" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Detiene el servicio DiagTrack y bloquea el envío de diagnósticos corporativos." FontSize="10.5" Foreground="#64748B" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsTelemetryDisabled}" Command="{Binding ToggleTelemetryCommand}" Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>

                        <Separator Background="#334155" Margin="0,0,0,15"/>

                        <!-- Switch Informes de Error -->
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Desactivar Informes de Error" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Bloquea las notificaciones automáticas de errores de software a los servidores de Windows." FontSize="10.5" Foreground="#64748B" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsErrorReportingDisabled}" Command="{Binding ToggleErrorReportingCommand}" Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- TARJETA 2: MODO JUEGO / RENDIMIENTO -->
                <Border Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18">
                    <StackPanel>
                        <TextBlock Text="Modo Juego / Ultra Rendimiento" FontSize="16" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock Text="Adapte el equipo al máximo rendimiento en un clic:" FontSize="11" Foreground="#94A3B8" Margin="0,4,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Activar Modo Juego" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC"/>
                                <TextBlock Text="Cambia al plan de energía de Alto Rendimiento, suspende servicios como cola de impresión o bluetooth, y vacía la RAM física." FontSize="10.5" Foreground="#64748B" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox Grid.Column="1" IsChecked="{Binding IsGameModeEnabled}" Command="{Binding ToggleGameModeCommand}" Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>

                        <Separator Background="#334155" Margin="0,0,0,12"/>

                        <!-- Estado del Plan de Energía -->
                        <Grid>
                            <TextBlock Text="Plan de Energía Activo:" FontSize="11.5" Foreground="#64748B" VerticalAlignment="Center"/>
                            <Border CornerRadius="4" Padding="6,2" Background="#0F172A" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding ActivePowerScheme}" FontSize="11" FontWeight="Bold" Foreground="#10B981"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- COLUMNA 2: DNS SPEED TEST & OPTIMIZER -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Header -->
                        <RowDefinition Height="*"/>
                        <!-- DNS Cards -->
                        <RowDefinition Height="Auto"/>
                        <!-- Speed Test Panel -->
                        <RowDefinition Height="Auto"/>
                        <!-- Actions bar -->
                    </Grid.RowDefinitions>

                    <!-- Cabecera DNS -->
                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
                                      Fill="#818CF8" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Optimizador DNS" FontSize="16" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="Compara la latencia de los principales DNS públicos y aplica el más rápido." FontSize="11" Foreground="#64748B" Margin="0,4,0,0"/>
                        </StackPanel>
                        <ProgressBar HorizontalAlignment="Right" Width="70" Height="5" IsIndeterminate="True"
                                     Visibility="{Binding IsLoadingDns, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Tarjetas DNS -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DnsServers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1"
                                            CornerRadius="10" Padding="14,10" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Fila 1: Nombre + IP + badge ACTIVO / botón Aplicar -->
                                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding PrimaryIp, StringFormat=' · {0}'}" FontSize="10" Foreground="#475569" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                                                    <!-- Badge ACTIVO -->
                                                    <Border CornerRadius="6" Padding="8,3" Background="#1E1B4B"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="6" Height="6" Fill="#818CF8" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                            <TextBlock Text="ACTIVO" FontSize="9" FontWeight="Bold" Foreground="#818CF8"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <!-- Botón Aplicar -->
                                                    <Button Content="⚡ Aplicar" Height="24" FontSize="10" Padding="10,0"
                                                            Command="{Binding DataContext.ApplyDnsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Visibility="{Binding IsActive, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                                                <Setter Property="Background" Value="#4F46E5"/>
                                                                <Setter Property="BorderThickness" Value="0"/>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Fila 2: Barra de latencia coloreada por rango -->
                                            <Grid Grid.Row="1" Margin="0,0,0,5">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="#1E293B" CornerRadius="4" Height="10">
                                                    <ProgressBar Value="{Binding LatencyProgressValue, Mode=OneWay}" Maximum="100"
                                                                 Height="10" VerticalAlignment="Stretch">
                                                        <ProgressBar.Style>
                                                            <Style TargetType="ProgressBar" BasedOn="{StaticResource ModernProgressBar}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding LatencyMs}" Value="999">
                                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ProgressBar.Style>
                                                    </ProgressBar>
                                                </Border>
                                                <!-- Etiqueta de latencia en ms -->
                                                <TextBlock Grid.Column="1" Text="{Binding LatencyText}"
                                                           FontSize="11" FontWeight="Bold" Foreground="#10B981"
                                                           Margin="10,0,0,0" VerticalAlignment="Center" Width="48" TextAlignment="Right"/>
                                            </Grid>

                                            <!-- Fila 3: Estado -->
                                            <TextBlock Grid.Row="2" Text="{Binding Status}" FontSize="9.5"
                                                       Foreground="#475569"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- ═══ PANEL SPEED TEST DE INTERNET ═══ -->
                    <Border Grid.Row="2" Background="#0B1220" BorderBrush="#1E3A5F" BorderThickness="1"
                            CornerRadius="10" Padding="14" Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Cabecera Speed Test -->
                            <Grid Grid.Row="0" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17.93V18c0-.55-.45-1-1-1s-1 .45-1 1v1.93C7.06 19.44 4.56 16.94 4.07 14H6c.55 0 1-.45 1-1s-.45-1-1-1H4.07C4.56 9.06 7.06 6.56 10 6.07V8c0 .55.45 1 1 1s1-.45 1-1V6.07c2.94.49 5.44 2.99 5.93 5.93H16c-.55 0-1 .45-1 1s.45 1 1 1h1.93c-.49 2.94-2.99 5.44-5.93 5.93zM12 11c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1z"
                                          Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Speed Test de Descarga" FontSize="13" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="vía Cloudflare CDN" FontSize="10" Foreground="#334155"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Resultado y barra de Mbps -->
                            <Grid Grid.Row="1" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#1E293B" CornerRadius="5" Height="14">
                                    <ProgressBar Value="{Binding InternetSpeedMbps, Mode=OneWay}"
                                                 Maximum="300" Height="14" VerticalAlignment="Stretch"
                                                 Style="{StaticResource ModernProgressBar}"/>
                                </Border>
                                <TextBlock Grid.Column="1" Text="{Binding SpeedTestStatusText}"
                                           FontSize="11" FontWeight="Bold" Foreground="#60A5FA"
                                           Margin="10,0,0,0" VerticalAlignment="Center" Width="140" TextAlignment="Right"/>
                            </Grid>

                            <!-- Botón Speed Test + loader -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Command="{Binding RunSpeedTestCommand}" Padding="14,8" Height="34">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                            <Setter Property="Background" Value="#1D4ED8"/>
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="M15.9 5.1C14.4 3.8 12.5 3 10.5 3c-4.1 0-7.5 3.4-7.5 7.5S6.4 18 10.5 18c3.3 0 6.1-2 7.2-5h-2.2c-1 2-3 3-5 3-3.3 0-6-2.7-6-6s2.7-6 6-6c1.6 0 3.1.6 4.2 1.7l-3.2 3.3H18V3l-2.1 2.1z"
                                              Fill="White" Width="14" Height="14" Stretch="Uniform" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="Medir Velocidad" FontSize="12" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <ProgressBar Grid.Column="1" Width="50" Height="5" IsIndeterminate="True"
                                             Margin="10,0,0,0" VerticalAlignment="Center"
                                             Visibility="{Binding IsSpeedTesting, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Barra de acciones DNS -->
                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="🔍 Probar Latencias" Command="{Binding RunDnsTestCommand}"
                                Style="{StaticResource ActionButton}" Padding="14,8"/>
                        <Button Grid.Column="1" Content="⚡ Aplicar DNS más rápido" Command="{Binding ApplyFastestDnsCommand}"
                                Style="{StaticResource ActionButton}" Margin="8,0,0,0" Padding="14,8"/>
                        <Button Grid.Column="2" Content="🧹 Flush DNS" Command="{Binding FlushDnsCommand}" Margin="8,0,0,0" Padding="14,8">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Setter Property="BorderBrush" Value="#334155"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="14,8"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border CornerRadius="8" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#334155"/>
                                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="2" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="DNS Actual: " FontSize="11" Foreground="#64748B"/>
                    <TextBlock Text="{Binding ActiveDns}" FontSize="11" FontWeight="SemiBold" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
