<UserControl x:Class="WinCleaner.Views.CrashInspectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:CrashInspectorViewModel}"
             d:DesignHeight="650" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="🚨 Inspector de Fallos" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
            <TextBlock Text="Analiza el registro de eventos de Windows para identificar cierres inesperados de aplicaciones, pantallas azules y fallos críticos." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- TARJETAS DE RESUMEN -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Tarjeta Total Incidentes -->
            <Border Grid.Column="0" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="TOTAL INCIDENTES DETECTADOS" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding TotalCrashesCount}" FontSize="24" FontWeight="Bold" Foreground="#6366F1" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Tarjeta Incidentes Críticos -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="INCIDENTES CRÍTICOS / BSOD" FontSize="10" FontWeight="Bold" Foreground="#94A3B8"/>
                    <TextBlock Text="{Binding CriticalCrashesCount}" FontSize="24" FontWeight="Bold" Foreground="#EF4444" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- BARRA DE HERRAMIENTAS Y BÚSQUEDA -->
        <Border Grid.Row="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="🔍 Analizar Bitácora"
                        Command="{Binding LoadCrashesCommand}"
                        Style="{StaticResource ActionButton}"
                        Margin="0,0,12,0"/>

                <Grid Grid.Column="1" Margin="0,0,12,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="#0F172A" Foreground="#F8FAFC" BorderBrush="#334155"
                             BorderThickness="1" Padding="10,6" VerticalAlignment="Center"
                             FontSize="13"/>
                    <TextBlock Text="Buscar por origen, ID de evento o descripción..."
                               Foreground="#64748B" IsHitTestVisible="False" VerticalAlignment="Center"
                               Margin="12,0,0,0" FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchText}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- LISTA DE INCIDENTES -->
        <Border Grid.Row="3" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="10" Padding="10">
            <ListView ItemsSource="{Binding Crashes}" SelectedItem="{Binding SelectedCrash}"
                      Style="{StaticResource ModernListView}" ItemContainerStyle="{StaticResource ModernListViewItem}">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Fecha / Hora" Width="140" DisplayMemberBinding="{Binding TimestampText}"/>
                        <GridViewColumn Header="Origen / Origen de Evento" Width="200" DisplayMemberBinding="{Binding Source}"/>
                        <GridViewColumn Header="Nivel" Width="80" DisplayMemberBinding="{Binding Level}"/>
                        <GridViewColumn Header="ID Evento" Width="80" DisplayMemberBinding="{Binding EventId}"/>
                        <GridViewColumn Header="Resumen del Incidente" Width="380" DisplayMemberBinding="{Binding Description}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <!-- PANEL DE DETALLE DE EVENTO SELECCIONADO -->
        <Border Grid.Row="4" Background="#0B0F19" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,12,0,0"
                Visibility="{Binding SelectedCrash, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Detalles del Registro de Evento (Mensaje Completo)" FontSize="12" FontWeight="Bold" Foreground="#64748B"/>
                </StackPanel>

                <TextBox Grid.Row="1"
                         Text="{Binding SelectedCrash.RawMessage, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MaxHeight="120"
                         VerticalScrollBarVisibility="Auto"
                         Background="Transparent"
                         Foreground="#CBD5E1"
                         FontFamily="Consolas, Cascadia Code, Courier New"
                         FontSize="11.5"
                         BorderThickness="0"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
