<UserControl x:Class="WinCleaner.Views.CleanupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Registro del Conversor Booleano a Visibilidad de WPF -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Estilo para ComboBox Moderno -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#1E293B"/>
                        <Setter Property="Foreground" Value="#F8FAFC"/>
                        <Setter Property="Padding" Value="8,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para TextBox Moderno -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="CaretBrush" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Panel de Acciones Rápidas -->
            <RowDefinition Height="Auto"/>
            <!-- Panel de Filtros -->
            <RowDefinition Height="Auto"/>
            <!-- Lista de Resultados -->
            <RowDefinition Height="*"/>
            <!-- Pie de Estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Limpieza Avanzada de Sistema" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Analice y limpie archivos innecesarios de forma segura. Seleccione individualmente qué elementos eliminar." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- PANEL DE ACCIONES RÁPIDAS -->
        <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="Analizar Sistema" Style="{StaticResource ActionButton}" Command="{Binding ScanCommand}" IsEnabled="{Binding CanScan}" Margin="0,0,10,0"/>
                
                <Button Grid.Column="1" Content="Cancelar" Style="{StaticResource SidebarButton}" Command="{Binding CancelScanCommand}" IsEnabled="{Binding IsScanning}" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Analizando directorios..." FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" Height="6" Style="{StaticResource ModernProgressBar}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="10,0" Visibility="{Binding IsCleaning, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Eliminando elementos..." FontSize="11" Foreground="#94A3B8" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" Height="6" Style="{StaticResource ModernProgressBar}"/>
                </StackPanel>

                <Button Grid.Column="3" Content="Ejecutar Limpieza" Command="{Binding CleanCommand}" IsEnabled="{Binding CanClean}" Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                            <Setter Property="Background" Value="#EF4444"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#DC2626"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#475569"/>
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>

        <!-- PANEL DE FILTROS Y ORDENACIÓN -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Búsqueda -->
            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0">
                <!-- Caja de texto de búsqueda en tiempo real -->
            </TextBox>

            <!-- Categoría -->
            <ComboBox Grid.Column="1" Style="{StaticResource ModernComboBox}" ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="150" Margin="0,0,10,0"/>

            <!-- Ordenar Por -->
            <ComboBox Grid.Column="2" Style="{StaticResource ModernComboBox}" SelectedValuePath="Content" SelectedValue="{Binding CurrentSortOption}" Width="120" Margin="0,0,10,0">
                <ComboBoxItem Content="Tamaño"/>
                <ComboBoxItem Content="Nombre"/>
                <ComboBoxItem Content="Tipo"/>
            </ComboBox>

            <!-- Dirección de Ordenación -->
            <ComboBox Grid.Column="3" Style="{StaticResource ModernComboBox}" SelectedValuePath="Content" SelectedValue="{Binding CurrentSortDirection}" Width="130" Margin="0,0,10,0">
                <ComboBoxItem Content="Descendente"/>
                <ComboBoxItem Content="Ascendente"/>
            </ComboBox>

            <!-- Acciones de Selección Colectiva -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="✓ Todo" Style="{StaticResource SidebarButton}" Command="{Binding ToggleAllSelectionCommand}" CommandParameter="True" Padding="8,5" Margin="0,0,5,0"/>
                <Button Content="✗ Ninguno" Style="{StaticResource SidebarButton}" Command="{Binding ToggleAllSelectionCommand}" CommandParameter="False" Padding="8,5"/>
            </StackPanel>
        </Grid>

        <!-- LISTA DE RESULTADOS -->
        <ListView Grid.Row="3" ItemsSource="{Binding DisplayItems}" Style="{StaticResource ModernListView}" ItemContainerStyle="{StaticResource ModernListViewItem}">
            <ListView.View>
                <GridView>
                    <!-- Columna de Selección -->
                    <GridViewColumn Width="45">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Tipo -->
                    <GridViewColumn Header="Categoría" Width="130">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FileType}" FontSize="12" Foreground="#818CF8" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Nombre -->
                    <GridViewColumn Header="Nombre" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold" Foreground="#F8FAFC" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Tamaño -->
                    <GridViewColumn Header="Tamaño" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SizeText}" FontSize="12" Foreground="#10B981" FontWeight="SemiBold"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Ruta -->
                    <GridViewColumn Header="Ruta Completa" Width="360">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#64748B" TextTrimming="CharacterEllipsis">
                                    <TextBlock.ToolTip>
                                        <ToolTip Content="{Binding Path}"/>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="4" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Encontrado: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalFoundSizeText}" FontSize="12" Foreground="#F8FAFC" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                    
                    <TextBlock Text="Seleccionado: " FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedSizeText}" FontSize="12" Foreground="#10B981" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
