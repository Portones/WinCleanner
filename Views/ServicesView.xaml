<UserControl x:Class="WinCleaner.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WinCleaner.Views"
             xmlns:vm="clr-namespace:WinCleaner.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <!-- Cabecera -->
            <RowDefinition Height="Auto"/>
            <!-- Búsqueda y barra de carga -->
            <RowDefinition Height="Auto"/>
            <!-- Contenido principal dividido -->
            <RowDefinition Height="*"/>
            <!-- Pie de estado -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- CABECERA -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Gestor de Servicios de Windows" FontSize="26" FontWeight="Bold" Foreground="#F8FAFC"/>
                <TextBlock Text="Inicie, detenga o cambie la configuración de inicio de los servicios de Windows. Los servicios esenciales están protegidos." FontSize="12" Foreground="#888888" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- PANEL DE BÚSQUEDA Y ACCIONES -->
        <Border Grid.Row="1" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Barra de búsqueda -->
                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Background="#0B0F19" Foreground="#F8FAFC" BorderBrush="#334155" BorderThickness="1" Padding="10,8" FontSize="13">
                        <!-- Placeholder/Sugerencia en el campo de texto -->
                        <TextBox.Resources>
                            <Style TargetType="{x:Type TextBox}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                            <Border x:Name="bg" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" CornerRadius="6">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                    <TextBlock x:Name="placeholder" Text="Buscar servicio por nombre..." FontSize="13" Foreground="#475569" Margin="10,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="Text" Value="">
                                                    <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#6366F1"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="Actualizar" Style="{StaticResource ActionButton}" Command="{Binding LoadServicesCommand}" Padding="20,8"/>
                    <ProgressBar Width="100" Height="6" Margin="15,0,0,0" IsIndeterminate="True" 
                                 Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                                 VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL DIVIDIDO -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- Lista de servicios -->
                <ColumnDefinition Width="*"/>
                <!-- Espaciador -->
                <ColumnDefinition Width="15"/>
                <!-- Panel de Detalles -->
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- COLUMNA 0: LISTA DE SERVICIOS -->
            <ListView Grid.Column="0" ItemsSource="{Binding FilteredServices}" SelectedItem="{Binding SelectedService}"
                      Style="{StaticResource ModernListView}" ItemContainerStyle="{StaticResource ModernListViewItem}">
                <ListView.View>
                    <GridView>
                        <!-- Nombre del servicio (Display) -->
                        <GridViewColumn Header="Nombre del Servicio" Width="260">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold" Foreground="#F8FAFC" TextTrimming="CharacterEllipsis"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Estado (En ejecución/Detenido) -->
                        <GridViewColumn Header="Estado" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                        <Setter Property="Background" Value="#10B981"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                                        <Setter Property="Background" Value="#475569"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" Foreground="#0F172A"/>
                                    </Border>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Tipo de Inicio (Automático/Manual/Deshabilitado) -->
                        <GridViewColumn Header="Inicio" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StartType}" FontSize="11" Foreground="#94A3B8"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- COLUMNA 2: DETALLES DEL SERVICIO SELECCIONADO -->
            <Border Grid.Column="2" Background="#1E293B" BorderBrush="#334155" BorderThickness="1" CornerRadius="12" Padding="20">
                <Grid>
                    <!-- Vista cuando no hay servicio seleccionado -->
                    <Grid Visibility="{Binding IsServiceSelected, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Ningún servicio seleccionado" FontSize="14" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center" TextAlignment="Center"/>
                            <TextBlock Text="Seleccione un servicio de la lista de la izquierda para ver sus detalles y poder administrarlo." FontSize="11" Foreground="#475569" TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Vista del Servicio Seleccionado -->
                    <Grid Visibility="{Binding IsServiceSelected, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <!-- Nombre e Icono -->
                            <TextBlock Text="{Binding SelectedService.DisplayName}" FontSize="16" FontWeight="Bold" Foreground="#F8FAFC" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding SelectedService.Name, StringFormat='Nombre del sistema: {0}'}" FontSize="11" Foreground="#64748B" Margin="0,4,0,15"/>

                            <!-- Alerta de Servicio Crítico -->
                            <Border Background="#7F1D1D" BorderBrush="#EF4444" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,15"
                                    Visibility="{Binding SelectedService.IsCritical, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="SERVICIO CRÍTICO" FontSize="11" FontWeight="Bold" Foreground="#FCA5A5"/>
                                    <TextBlock Text="Este servicio es esencial para el correcto funcionamiento de Windows. No se puede detener ni modificar por seguridad." FontSize="10" Foreground="#FCA5A5" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Separator Background="#334155" Margin="0,0,0,15"/>

                            <!-- Estado actual -->
                            <TextBlock Text="Estado del Servicio" FontSize="12" Foreground="#94A3B8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,15">
                                <Border CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedService.IsRunning}" Value="True">
                                                    <Setter Property="Background" Value="#10B981"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding SelectedService.IsRunning}" Value="False">
                                                    <Setter Property="Background" Value="#475569"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding SelectedService.Status}" FontSize="11" FontWeight="Bold" Foreground="#0F172A"/>
                                </Border>
                            </StackPanel>

                            <!-- Acciones de Ejecución -->
                            <TextBlock Text="Acciones" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,6"/>
                            <!-- Botón Iniciar -->
                            <Button Content="Iniciar Servicio" Style="{StaticResource ActionButton}" Command="{Binding StartServiceCommand}" 
                                    Visibility="{Binding SelectedService.IsRunning, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                    IsEnabled="{Binding CanStartSelected}" Margin="0,0,0,8"/>
                            
                            <!-- Botón Detener -->
                            <Button Content="Detener Servicio" Command="{Binding StopServiceCommand}" 
                                    Visibility="{Binding SelectedService.IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    IsEnabled="{Binding CanStopSelected}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#991B1B"/>
                                        <Setter Property="Foreground" Value="#F8FAFC"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="15,10"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" CornerRadius="8" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="border" Property="Background" Value="#B91C1C"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="border" Property="Background" Value="#475569"/>
                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- Panel de tipo de inicio (Arranque) -->
                        <StackPanel Grid.Row="1" Margin="0,15,0,0">
                            <Separator Background="#334155" Margin="0,0,0,15"/>
                            <TextBlock Text="Tipo de Inicio (Arranque)" FontSize="12" Foreground="#94A3B8" Margin="0,0,0,8"/>
                            
                            <!-- Lista de Botones para cambiar tipo de inicio -->
                            <UniformGrid Columns="3" IsEnabled="{Binding CanModifySelected}">
                                <Button Content="Auto" Command="{Binding ChangeStartTypeCommand}" CommandParameter="Automático" Margin="0,0,4,0" FontSize="11" Padding="5,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedService.StartType}" Value="Automático">
                                                    <Setter Property="Background" Value="#6366F1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Manual" Command="{Binding ChangeStartTypeCommand}" CommandParameter="Manual" Margin="2,0,2,0" FontSize="11" Padding="5,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedService.StartType}" Value="Manual">
                                                    <Setter Property="Background" Value="#6366F1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Deshab." Command="{Binding ChangeStartTypeCommand}" CommandParameter="Deshabilitado" Margin="4,0,0,0" FontSize="11" Padding="5,8">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                            <Setter Property="Background" Value="#334155"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedService.StartType}" Value="Deshabilitado">
                                                    <Setter Property="Background" Value="#6366F1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- PIE DE ESTADO -->
        <Border Grid.Row="3" Background="#0B0F19" BorderBrush="#334155" BorderThickness="0,1,0,0" Padding="12,10" Margin="0,10,0,0">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#94A3B8" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
